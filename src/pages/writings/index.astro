---
import "../../styles/global.css"
import BaseLayout from "../../layouts/BaseLayout.astro"
import ArticleCard from "../../components/ArticleCard.astro"
import { getCollection } from "astro:content"
const writings = (await getCollection("writings")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const title = "Writings"
const description = "Articles on software development, team leadership, human-computer interaction, and agile processes by Arttu Viljakainen."
---
<BaseLayout title={title} description={description}>
  <div class="writings-container">
        <header class="writings-header">
            <p class="writings-kicker">LONG FORM</p>
            <h1>{title}</h1>
            <p class="writings-intro">
                Essays and articles on software, systems, research, and people. Longer pieces where there is room to think matters through.
            </p>
            <p class="writings-note">
                Comments can be posted on Mastodon.
            </p>
        </header>
    <div class="writing-listing">
      {writings.map((post, index) => (
        <ArticleCard post={post} featured={index === 0} />
      ))}
    </div>
  </div>
</BaseLayout>
<style>

    .writings-header {
        margin: 0 0 2.5rem;
        padding: 0 0 1.25rem;
        border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
    }

    .writings-kicker {
        margin: 0 0 0.4rem;
        font-family: var(--font-mono);
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--color-muted);
    }

    .writings-header h1 {
        margin: 0;
    }

    .writings-intro {
        max-width: 38rem;
        margin: 0.7rem 0 0;
        color: var(--color-muted);
        font-size: 1.02rem;
        line-height: 1.68;
    }

    .writings-note {
        max-width: 34rem;
        margin: 0.85rem 0 0;
        font-family: var(--font-condensed);
        font-size: 0.92rem;
        line-height: 1.55;
        color: color-mix(in srgb, var(--color-text) 72%, #6c5d53 28%);
    }

    .writing-listing {
        min-height: 80vh;
    }

    a {
        text-decoration: none;
    }

    ul {
        list-style-type: none;
        padding-left: 1rem;
        width: 100%;
    }

    ul li {
        display: flex;
        padding-bottom: 0.8rem;
    }

    ul li :global(time) {
        text-align: right;
        flex: 0 0 10rem;
    }

    .writings-container {
        max-width: 58rem;
        margin: 0 auto;
        padding-top: 1.25rem;
    }

    @media (max-width: 800px) {
        .writing-listing ul li {
            font-size: smaller;
        }

        ul li :global(time) {
            flex: 0 0 6rem;
        }
    }

    @media (max-width: 459px) {
        .writings-container {
            padding-top: 0.9rem;
        }

        .writing-listing ul li {
            padding-bottom: 0.3rem;
        }

        ul li :global(time) {
            flex: 0 0 5rem;
        }

    }


</style>