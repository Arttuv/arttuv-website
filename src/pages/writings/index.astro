---
import "../../styles/global.css"
import BaseLayout from "../../layouts/BaseLayout.astro"
import ArticleCard from "../../components/ArticleCard.astro"
import { getCollection } from "astro:content"
const writings = (await getCollection("writings")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const title = "Writings"
const description = "Articles on software development, team leadership, human-computer interaction, and agile processes by Arttu Viljakainen."
---
<BaseLayout title={title} description={description}>
  <div class="writings-container">
    <h1>{title}</h1>
    <div class="writing-listing">
      {writings.map((post, index) => (
        <ArticleCard post={post} featured={index === 0} />
      ))}
    </div>
  </div>
</BaseLayout>
<style>

    .writing-listing {
        min-height: 80vh;
    }

    a {
        text-decoration: none;
    }

    ul {
        list-style-type: none;
        padding-left: 1rem;
        width: 100%;
    }

    ul li {
        display: flex;
        padding-bottom: 0.8rem;
    }

    ul li :global(time) {
        text-align: right;
        flex: 0 0 10rem;
    }

    .writings-container {
        max-width: 58rem;
        margin: 0 auto;
    }

    @media (max-width: 800px) {
        .writing-listing ul li {
            font-size: smaller;
        }

        ul li :global(time) {
            flex: 0 0 6rem;
        }
    }

    @media (max-width: 459px) {
        .writing-listing ul li {
            padding-bottom: 0.3rem;
        }

        ul li :global(time) {
            flex: 0 0 5rem;
        }

    }


</style>