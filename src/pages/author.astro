---
import "../styles/global.css"
import { Image } from "astro:assets"
import BaseLayout from "../layouts/BaseLayout.astro"
import BauhausBlock from "../components/BauhausBlock.astro"
import arttu from "../images/arttuv-bw.jpeg"
const title = "Arttu Viljakainen"
const description = "Arttu Viljakainen is a software development consultant from Finland."
---

<BaseLayout title={title} description={description}>
  <div class="author-page">

    <div class="author-hero">
      <div class="author-hero-text">
        <BauhausBlock slug="author" tags={["dev", "hci", "research"]} direction="horizontal" />
        <h1>Arttu Viljakainen</h1>
        <p class="author-role">Software development consultant</p>
        <p>
          I love solving complex problems and working collaboratively with teams to achieve great outcomes.
          With close to 15 years of experience, I'm a generalist who enjoys a variety of challenges and
          constantly learning new things.
        </p>
        <p>
          My focus is on hands-on software development, but I believe the performance of a team matters
          more than any individual's skills. I'm passionate about studying and improving teamwork and
          shared leadership, helping teams work effectively together without relying on command and control.
        </p>
        <p>
          I find meaning in doing work that matters. I love environments where teams have high autonomy
          and can self-organise. Titles don't define what you can do. What matters is making good things happen.
        </p>
        <p>
          Humans as collaborative digital tool makers is an interesting viewpoint.
        </p>
        <p class="author-links">
          <a href="https://scholar.social/@arttuv">Mastodon</a>
          <a href="https://www.linkedin.com/in/arttu-viljakainen/">LinkedIn</a>
          <a href="https://www.swdevcollective.com">Developer Collective</a>
        </p>
      </div>
      <div class="author-hero-photo">
        <Image src={arttu} alt="Arttu Viljakainen" loading="eager" />
      </div>
    </div>

    <div class="author-skills">
      <div class="skill-section skill-section--dev">
        <p class="skill-label">Technical</p>
        <ul>
          <li>JVM: Java, Kotlin (10+ years)</li>
          <li>Web: React, Node, TypeScript, HTML/CSS</li>
          <li>Databases: PostgreSQL, MariaDB, ElasticSearch</li>
          <li>Cloud: Kubernetes, AWS, containers</li>
          <li>GoLang, Android, Jetpack Compose, Delphi</li>
        </ul>
        <p class="skill-note">Cloud native systems, Android tablets, desktop applications. Public sector, defence, and commercial.</p>
      </div>
      <div class="skill-section skill-section--hci">
        <p class="skill-label">Leadership &amp; process</p>
        <ul>
          <li>Advanced Certified ScrumMaster (A-CSM)</li>
          <li>Certified ScrumMaster (CSM)</li>
          <li>Certified Scrum Product Owner (CSPO)</li>
          <li>Certified SAFe 5 Practitioner</li>
          <li>Reaktor Team Builder Academy (2021)</li>
          <li>Reaktor Leading Teams (2021)</li>
        </ul>
        <p class="skill-note">Certifications reflect experience, not endorsement. I prefer letting teams find their own way of working.</p>
      </div>
      <div class="skill-section skill-section--research">
        <p class="skill-label">Education</p>
        <ul>
          <li><strong>MSc</strong>, University of Eastern Finland (2012)</li>
          <li>Major: Computer Science, software engineering</li>
          <li>Minors: psychology, cognitive science, business economics</li>
          <li>PhD studies at Tampere University (on hold)</li>
          <li>Research focus: teamwork in software development</li>
        </ul>
        <ul>
          <li>Finnish (native), English (advanced), Swedish (basics)</li>
        </ul>
      </div>
    </div>

    <div class="line-heading"><h2>Work history</h2></div>

    <div class="cv-listing">
      <div class="cv-item-time"><span>Now</span></div>
      <div class="cv-item-content">
        <p>Full time at Reaktor, studying teamwork on the side.</p>
      </div>

      <div class="cv-item-time"><span>2019</span></div>
      <div class="cv-item-content">
        <p class="cv-company">Reaktor <span class="cv-current">→ current</span></p>
        <p>Software consultancy. My roles have varied from senior full-stack developer to team lead, scrum master, and agile coach.</p>
      </div>

      <div class="cv-item-time"><span>2014</span></div>
      <div class="cv-item-content">
        <p class="cv-company">Insta DefSec Oy</p>
        <p>Senior software engineer, team lead &amp; scrum master, usability specialist.</p>
      </div>

      <div class="cv-item-time"><span>2013</span></div>
      <div class="cv-item-content">
        <p class="cv-company">Suonentieto Oy</p>
        <p>Delphi application developer.</p>
      </div>

      <div class="cv-item-time"><span>2010</span></div>
      <div class="cv-item-content">
        <p class="cv-company">CGI / Logica</p>
        <p>Java and XSLT transformations in a large SAP PI integration project.</p>
      </div>

      <div class="cv-item-time"><span>2008</span></div>
      <div class="cv-item-content">
        <p class="cv-company">European Forest Institute</p>
        <p>Java developer trainee, summer 2008.</p>
      </div>
    </div>

    <div class="author-origin">
      <p>
        I started programming around 1999 in QBasic, and then in Turbo Pascal. No internet, just library books and trial and error —
        building ASCII games with nothing but <code>IF-ELSE</code> technology. I loved it, best years of computing for me. I got so addicted in coding that it somewhat displaced gaming for me.
      </p>
      <p>
        That spark never went away. I never really thought of doing anything else for a living.
      </p>
    </div>

  </div>
</BaseLayout>

<style>
    .author-page {
        max-width: 70ch;
        margin: 0 auto;
    }

    /* Hero */
    .author-hero {
        display: flex;
        flex-direction: row;
        gap: 2rem;
        align-items: flex-start;
        margin-top: 2rem;
    }

    .author-hero-text {
        flex: 1;
        min-width: 0;
    }

    .author-hero-text h1 {
        margin-top: 1.5rem;
        margin-bottom: 0.25rem;
    }

    .author-hero-text p {
        line-height: 1.65;
        margin-bottom: 1rem;
    }

    .author-role {
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #666;
        margin-bottom: 1.25rem !important;
    }

    :global(.dark) .author-role {
        color: #aaa;
    }

    .author-links {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.85rem;
    }

    .author-links a {
        text-decoration: none;
    }

    .author-links a:hover {
        text-decoration: underline;
    }

    .author-hero-photo {
        width: 160px;
        flex-shrink: 0;
    }

    .author-hero-photo img {
        width: 100%;
        height: auto;
        display: block;
        border: 1px solid lightgray;
        border-radius: 0.5rem;
    }

    /* Skills */
    .author-skills {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1.5rem;
        margin: 2.5rem 0;
    }

    .skill-section {
        border-top: 3px solid;
        padding-top: 0.75rem;
    }

    .skill-section--dev   { border-color: #C62828; }
    .skill-section--hci   { border-color: #1565C0; }
    .skill-section--research { border-color: #F9A825; }

    .skill-label {
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #888;
        margin: 0 0 0.75rem;
    }

    .skill-section ul {
        padding-left: 1rem;
        margin: 0 0 0.75rem;
        font-size: 0.8rem;
        line-height: 1.6;
    }

    .skill-section li + li {
        margin-top: 0.2rem;
    }

    .skill-note {
        font-size: 0.75rem;
        color: #777;
        line-height: 1.5;
        margin: 0;
    }

    :global(.dark) .skill-note {
        color: #999;
    }

    /* CV timeline */
    .cv-listing {
        display: grid;
        grid-template-columns: 4.5rem 1fr;
        margin-bottom: 1.5rem;
    }

    .cv-item-time {
        text-align: right;
        padding-right: 1rem;
        border-right: 1px solid lightgray;
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.8rem;
        color: #666;
        padding-top: 0.2rem;
        position: relative;
    }

    .cv-item-time span::after {
        content: '';
        position: absolute;
        right: -0.45rem;
        top: 0.45rem;
        width: 0.8rem;
        height: 0.8rem;
        border-radius: 50%;
        background-color: #C62828;
        border: 2px solid #fffbf8;
    }

    :global(.dark) .cv-item-time span::after {
        border-color: #000;
    }

    .cv-item-content {
        padding: 0 0 1.25rem 1.25rem;
        font-size: 0.875rem;
        line-height: 1.6;
    }

    .cv-item-content p {
        margin: 0 0 0.3rem;
    }

    .cv-company {
        font-weight: 600;
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.9rem;
    }

    .cv-current {
        font-weight: 400;
        color: #C62828;
        font-size: 0.8rem;
    }

    :global(.dark) .cv-item-time {
        color: #aaa;
    }

    /* Origin story */
    .author-origin {
        font-size: 0.875rem;
        line-height: 1.65;
        color: #555;
        border-top: 1px solid lightgray;
        padding-top: 1.25rem;
        margin-bottom: 2rem;
    }

    .author-origin p {
        margin-bottom: 0.75rem;
    }

    :global(.dark) .author-origin {
        color: #aaa;
    }

    @media (max-width: 800px) {
        .author-hero {
            flex-direction: column-reverse;
            gap: 1rem;
            align-items: center;
        }

        .author-hero-photo {
            width: 100%;
            max-width: 20ch;
        }

        .author-skills {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }
</style>
