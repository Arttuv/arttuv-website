---
import HeaderLink from "./HeaderLink.astro"
import SocialLinks from "./SocialLinks.astro"
import ThemeIcon from "./ThemeIcon.astro"
import MobileMenu from "./MobileMenu.astro"
---
<header>
  <div class="desktop-navigation">
    <nav>
      <ul>
        <li><HeaderLink href="/">Home</HeaderLink></li>
        <li><HeaderLink href="/writings">Writings</HeaderLink></li>
        <li><HeaderLink href="/author">Author</HeaderLink></li>
      </ul>
    </nav>
    <span class="site-title">
      <a href="/">Arttu Viljakainen</a>
    </span>
    <div class="header-right">
      <div class="header-social">
        <SocialLinks />
      </div>
      <div class="theme-switcher">
        <ThemeIcon />
      </div>
    </div>
  </div>
  <MobileMenu />
  <div class="header-cat" aria-hidden="true">
    <svg viewBox="0 0 21 19" width="21" height="19" shape-rendering="crispEdges" fill="currentColor">
      <!-- ears -->
      <rect x="1" y="0" width="1" height="1"/>
      <rect x="5" y="0" width="1" height="1"/>
      <rect x="1" y="1" width="1" height="1"/>
      <rect x="2" y="1" width="1" height="1"/>
      <rect x="4" y="1" width="1" height="1"/>
      <rect x="5" y="1" width="1" height="1"/>
      <!-- head -->
      <rect x="1" y="2" width="1" height="1"/>
      <rect x="2" y="2" width="1" height="1"/>
      <rect x="3" y="2" width="1" height="1"/>
      <rect x="4" y="2" width="1" height="1"/>
      <rect x="5" y="2" width="1" height="1"/>
      <!-- eyes row -->
      <rect x="0" y="3" width="1" height="1"/>
      <rect class="cat-eye" x="1" y="3" width="1" height="1" fill="#FFF"/>
      <rect x="2" y="3" width="1" height="1"/>
      <rect x="4" y="3" width="1" height="1"/>
      <rect class="cat-eye" x="5" y="3" width="1" height="1" fill="#FFF"/>
      <rect x="6" y="3" width="1" height="1"/>
      <!-- nose/mouth -->
      <rect x="0" y="4" width="1" height="1"/>
      <rect x="3" y="4" width="1" height="1"/>
      <rect x="6" y="4" width="1" height="1"/>
      <!-- chin -->
      <rect x="1" y="5" width="1" height="1"/>
      <rect x="2" y="5" width="1" height="1"/>
      <rect x="3" y="5" width="1" height="1"/>
      <rect x="4" y="5" width="1" height="1"/>
      <rect x="5" y="5" width="1" height="1"/>
      <!-- body -->
      <rect x="1" y="6" width="1" height="1"/>
      <rect x="2" y="6" width="1" height="1"/>
      <rect x="3" y="6" width="1" height="1"/>
      <rect x="4" y="6" width="1" height="1"/>
      <rect x="5" y="6" width="1" height="1"/>
      <rect x="1" y="7" width="1" height="1"/>
      <rect x="2" y="7" width="1" height="1"/>
      <rect x="3" y="7" width="1" height="1"/>
      <rect x="4" y="7" width="1" height="1"/>
      <rect x="5" y="7" width="1" height="1"/>
      <rect x="1" y="8" width="1" height="1"/>
      <rect x="2" y="8" width="1" height="1"/>
      <rect x="3" y="8" width="1" height="1"/>
      <rect x="4" y="8" width="1" height="1"/>
      <rect x="5" y="8" width="1" height="1"/>
      <!-- paws (below border line) -->
      <rect x="1" y="9" width="1" height="1"/>
      <rect x="2" y="9" width="1" height="1"/>
      <rect x="4" y="9" width="1" height="1"/>
      <rect x="5" y="9" width="1" height="1"/>
      <!-- tail (hangs down from body right side) -->
      <rect x="6" y="7" width="1" height="1"/>
      <rect x="7" y="8" width="1" height="1"/>
      <rect x="7" y="9" width="1" height="1"/>
      <rect x="7" y="10" width="1" height="1"/>
      <rect x="8" y="11" width="1" height="1"/>
      <rect x="9" y="11" width="1" height="1"/>
    </svg>
    <span class="cat-speech">Mäy!</span>
  </div>
</header>
<style>

    .desktop-navigation {
        margin:0 auto;
        padding: 0.5rem 0 0.5rem 0;
        width: 100%;
        display: inline-flex;
        justify-content: space-between;
        align-items: center;
        flex-direction: row;
    }

    .header-right {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
    }

    .desktop-navigation .header-social {
        padding-right: 1rem;
    }

    .desktop-navigation .theme-switcher {
        min-width: 3vw;
        margin-right: 1.0875rem;
    }

    .site-title h1 {
        font-size: 18px;
        font-weight: 400;
    }

    .site-title a {
        text-align: center;
        text-shadow: none;
        background-image: none;
        text-decoration: none;
    }

    .header-social {
        text-align: right;
    }

    nav {
        padding-top:0;
        padding-bottom:0;
        margin-left: 1.0875rem;
    }

    nav ul {
        margin: 0;
        padding-inline-start: 0;
        text-align: left;
        list-style: none;
    }

    nav ul li {
        display: inline-block;
        margin-right: 0px;
        text-align: left;
        font-weight: 400;
    }

    nav ul li {
        margin-bottom: 0;
    }

    nav ul li:not(:last-child) {
        margin-right: 1rem;
    }

    @media (max-width: 800px) {

        .desktop-navigation {
            margin: 1rem 0 0 0;
        }

        .desktop-navigation {
            display: none;
        }

        nav {
            margin-left: 0.5rem;
        }

        nav ul li:not(:last-child) {
            margin-bottom: 0.5rem;
            margin-right:0;
        }

        nav ul {
            margin-bottom: 0px;
            padding-right: 0.5rem;
        }

        nav ul li {
            display: block;
            margin-right: 0px;
        }

        .header-social {
            display: flex;
            flex-direction: column-reverse;
        }

    }
</style>

<script>
  function initCatMau() {
    const cat = document.querySelector('.header-cat');
    if (!cat) return;
    const speech = cat.querySelector('.cat-speech');
    if (!speech) return;

    let timeout: ReturnType<typeof setTimeout>;
    cat.addEventListener('click', () => {
      speech.classList.add('visible');
      clearTimeout(timeout);
      timeout = setTimeout(() => speech.classList.remove('visible'), 1200);
    });
  }

  document.addEventListener('astro:page-load', initCatMau);
</script>