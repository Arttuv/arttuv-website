---
import HeaderLink from "./HeaderLink.astro"
import ThemeIcon from "./ThemeIcon.astro"
import MobileMenu from "./MobileMenu.astro"
---
<header class="site-header">
  <div class="desktop-navigation">
    <div class="header-left">
      <div class="header-left-top">
        <a href="/" class="site-brand" aria-label="Go to homepage">
          <span class="brand-mark" aria-hidden="true"><span class="brand-mark-fill"><span class="brand-mark-stripe" style="--i:0"></span><span class="brand-mark-stripe" style="--i:1"></span><span class="brand-mark-stripe" style="--i:2"></span><span class="brand-mark-stripe" style="--i:3"></span><span class="brand-mark-stripe" style="--i:4"></span><span class="brand-mark-stripe" style="--i:5"></span></span><span class="brand-mark-text">AV</span></span>
          <span class="brand-copy">
            <span class="brand-text">arttuv.com</span>
            <span class="brand-name">Arttu Viljakainen</span>
          </span>
        </a>

        <nav aria-label="Primary navigation">
          <ul>
            <li><HeaderLink href="/">Home</HeaderLink></li>
            <li><HeaderLink href="/writings/">Writings</HeaderLink></li>
            <li><HeaderLink href="/author/">Author</HeaderLink></li>
          </ul>
        </nav>
      </div>
      <span class="brand-tagline">A nordic approach to software, systems and people</span>
    </div>

    <div class="header-right">
      <div class="theme-switcher">
        <ThemeIcon />
      </div>
    </div>
  </div>
  <MobileMenu />
  <div class="header-cat" aria-hidden="true">
    <svg viewBox="0 0 21 19" width="21" height="19" shape-rendering="crispEdges" fill="currentColor">
      <!-- ears -->
      <rect x="1" y="0" width="1" height="1"/>
      <rect x="5" y="0" width="1" height="1"/>
      <rect x="1" y="1" width="1" height="1"/>
      <rect x="2" y="1" width="1" height="1"/>
      <rect x="4" y="1" width="1" height="1"/>
      <rect x="5" y="1" width="1" height="1"/>
      <!-- head -->
      <rect x="1" y="2" width="1" height="1"/>
      <rect x="2" y="2" width="1" height="1"/>
      <rect x="3" y="2" width="1" height="1"/>
      <rect x="4" y="2" width="1" height="1"/>
      <rect x="5" y="2" width="1" height="1"/>
      <!-- eyes row -->
      <rect x="0" y="3" width="1" height="1"/>
      <rect class="cat-eye" x="1" y="3" width="1" height="1" fill="#FFF"/>
      <rect x="2" y="3" width="1" height="1"/>
      <rect x="4" y="3" width="1" height="1"/>
      <rect class="cat-eye" x="5" y="3" width="1" height="1" fill="#FFF"/>
      <rect x="6" y="3" width="1" height="1"/>
      <!-- nose/mouth -->
      <rect x="0" y="4" width="1" height="1"/>
      <rect x="3" y="4" width="1" height="1"/>
      <rect x="6" y="4" width="1" height="1"/>
      <!-- chin -->
      <rect x="1" y="5" width="1" height="1"/>
      <rect x="2" y="5" width="1" height="1"/>
      <rect x="3" y="5" width="1" height="1"/>
      <rect x="4" y="5" width="1" height="1"/>
      <rect x="5" y="5" width="1" height="1"/>
      <!-- body -->
      <rect x="1" y="6" width="1" height="1"/>
      <rect x="2" y="6" width="1" height="1"/>
      <rect x="3" y="6" width="1" height="1"/>
      <rect x="4" y="6" width="1" height="1"/>
      <rect x="5" y="6" width="1" height="1"/>
      <rect x="1" y="7" width="1" height="1"/>
      <rect x="2" y="7" width="1" height="1"/>
      <rect x="3" y="7" width="1" height="1"/>
      <rect x="4" y="7" width="1" height="1"/>
      <rect x="5" y="7" width="1" height="1"/>
      <rect x="1" y="8" width="1" height="1"/>
      <rect x="2" y="8" width="1" height="1"/>
      <rect x="3" y="8" width="1" height="1"/>
      <rect x="4" y="8" width="1" height="1"/>
      <rect x="5" y="8" width="1" height="1"/>
      <!-- paws (below border line) -->
      <rect x="1" y="9" width="1" height="1"/>
      <rect x="2" y="9" width="1" height="1"/>
      <rect x="4" y="9" width="1" height="1"/>
      <rect x="5" y="9" width="1" height="1"/>
      <!-- tail (hangs down from body right side) -->
      <rect x="6" y="7" width="1" height="1"/>
      <rect x="7" y="8" width="1" height="1"/>
      <rect x="7" y="9" width="1" height="1"/>
      <rect x="7" y="10" width="1" height="1"/>
      <rect x="8" y="11" width="1" height="1"/>
      <rect x="9" y="11" width="1" height="1"/>
    </svg>
    <span class="cat-speech">Mäy!</span>
  </div>
</header>
<style>

    .desktop-navigation {
        margin:0 auto;
        padding: 0.95rem 1rem;
        width: 100%;
        box-sizing: border-box;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-direction: row;
        transition: padding 0.22s ease;
    }

    .site-header.site-header--compact .desktop-navigation {
      padding: 0.5rem 1rem;
    }

    .header-left {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      min-width: 0;
      transition: gap 0.22s ease;
    }

    .site-header.site-header--compact .header-left {
      gap: 0;
    }

    .header-left-top {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      min-width: 0;
      transition: gap 0.22s ease;
    }

    .site-header.site-header--compact .header-left-top {
      gap: 0.85rem;
    }

    .site-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      text-decoration: none;
      color: var(--color-text);
      line-height: 1;
    }

    .brand-copy {
      display: flex;
      flex-direction: column;
      gap: 0.14rem;
      line-height: 1;
    }

    .brand-mark {
      display: inline-grid;
      place-items: center;
      position: relative;
      overflow: hidden;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 0.3rem;
      border: 2px solid currentColor;
      font-family: var(--font-condensed);
      font-weight: 700;
      font-size: 1.2rem;
      line-height: 1;
      text-align: center;
      letter-spacing: 0.01em;
      transition: border-color 0.22s ease, width 0.22s ease, height 0.22s ease, font-size 0.22s ease;
      isolation: isolate;
    }

    .site-header.site-header--compact .brand-mark {
      width: 2rem;
      height: 2rem;
      font-size: 1rem;
    }

    .brand-mark-fill {
      position: absolute;
      inset: 0;
      border-radius: calc(0.3rem - 2px);
      overflow: hidden;
      clip-path: inset(0 round calc(0.3rem - 2px));
      -webkit-clip-path: inset(0 round calc(0.3rem - 2px));
    }

    .brand-mark-stripe {
      position: absolute;
      top: 0;
      bottom: 0;
      width: calc(100% / 6 + 1px);
      left: calc(var(--i) * 100% / 6);
      transform: translateY(-110%);
      opacity: 0;
    }

    .brand-mark-stripe:nth-child(1) { background: var(--color-red); }
    .brand-mark-stripe:nth-child(2) { background: var(--color-orange); }
    .brand-mark-stripe:nth-child(3) { background: var(--color-yellow); }
    .brand-mark-stripe:nth-child(4) { background: var(--color-green); }
    .brand-mark-stripe:nth-child(5) { background: var(--color-blue); }
    .brand-mark-stripe:nth-child(6) { background: var(--color-purple); }

    @keyframes stripe-slide-in {
      0%   { transform: translateY(-110%); opacity: 0; }
      40%  { opacity: 1; }
      100% { transform: translateY(0); opacity: 1; }
    }

    @keyframes stripe-slide-out {
      0%   { transform: translateY(0); opacity: 1; }
      60%  { opacity: 1; }
      100% { transform: translateY(110%); opacity: 0; }
    }

    .brand-mark-text {
      position: relative;
      z-index: 1;
      transition: color 0.3s ease;
    }

    .brand-mark--entering .brand-mark-text {
      color: #fff;
      transition: color 0.2s ease 0.12s;
    }

    html:not(.dark) .brand-mark--entering .brand-mark-text {
      color: inherit;
      transition: none;
    }

    .brand-mark--leaving .brand-mark-text {
      color: #fff;
    }

    html:not(.dark) .brand-mark--leaving .brand-mark-text {
      color: inherit;
    }

    .brand-text {
      font-family: var(--font-condensed);
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .brand-name {
      font-family: var(--font-serif);
      font-size: 0.84rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      line-height: 1.1;
      display: block;
      padding-bottom: 0.08rem;
      opacity: 0.9;
      max-height: 1.3rem;
      overflow: visible;
      transform: translateY(0);
      transition: opacity 0.22s ease, max-height 0.22s ease, transform 0.22s ease;
    }

    .site-header.site-header--compact .brand-name {
      opacity: 0;
      max-height: 0;
      overflow: hidden;
      transform: translateY(-4px);
    }

    .brand-tagline {
      font-family: var(--font-condensed);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      opacity: 0.7;
      max-height: 2rem;
      overflow: hidden;
      transform: translateY(0);
      transition: opacity 0.22s ease, max-height 0.22s ease, transform 0.22s ease;
      line-height: 1.3;
    }

    .site-header.site-header--compact .brand-tagline {
      opacity: 0;
      max-height: 0;
      transform: translateY(-4px);
    }

    @media (prefers-reduced-motion: reduce) {
      .desktop-navigation,
      .brand-name,
      .brand-tagline,
      .brand-mark-stripe {
        transition: none;
        animation: none;
      }
    }

    .header-right {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
    }

    .desktop-navigation .theme-switcher {
      margin-right: 0;
    }

    nav {
        padding-top:0;
        padding-bottom:0;
      margin-left: 0;
    }

    nav ul {
        margin: 0;
        padding-inline-start: 0;
        text-align: left;
        list-style: none;
    }

    nav ul li {
        display: inline-block;
        margin-right: 0px;
        text-align: left;
        font-weight: 400;
    }

    nav ul li {
        margin-bottom: 0;
    }

    nav ul li:not(:last-child) {
        margin-right: 1rem;
    }

    @media (max-width: 768px) {

        .desktop-navigation {
            margin: 1rem 0 0 0;
        }

        .desktop-navigation {
            display: none;
        }

        nav {
            margin-left: 0.5rem;
        }

        nav ul li:not(:last-child) {
            margin-bottom: 0.5rem;
            margin-right:0;
        }

        nav ul {
            margin-bottom: 0px;
            padding-right: 0.5rem;
        }

        nav ul li {
            display: block;
            margin-right: 0px;
        }

    }
</style>

<script>
  function initCatMau() {
    const cat = document.querySelector('.header-cat');
    if (!cat) return;
    const speech = cat.querySelector('.cat-speech');
    if (!speech) return;

    let timeout: ReturnType<typeof setTimeout>;
    cat.addEventListener('click', () => {
      speech.classList.add('visible');
      clearTimeout(timeout);
      timeout = setTimeout(() => speech.classList.remove('visible'), 1200);
    });
  }

  document.addEventListener('astro:page-load', initCatMau);

  function initAutoHideHeader() {
    const header = document.querySelector<HTMLElement>('.site-header');
    if (!header) return;
    const headerEl = header;

    const mobileQuery = window.matchMedia('(max-width: 768px)');
    let lastScrollY = window.scrollY;
    let ticking = false;

    function updateHeaderVisibility() {
      ticking = false;
      const currentScrollY = window.scrollY;

      if (!mobileQuery.matches) {
        headerEl.classList.toggle('site-header--compact', currentScrollY > 64);
        headerEl.classList.remove('site-header--hidden');
        return;
      }

      headerEl.classList.remove('site-header--compact');

      if (document.body.classList.contains('menu-open')) {
        headerEl.classList.remove('site-header--hidden');
        lastScrollY = window.scrollY;
        return;
      }

      const scrollingDown = currentScrollY > lastScrollY;
      const nearTop = currentScrollY < 24;

      if (nearTop || !scrollingDown) {
        headerEl.classList.remove('site-header--hidden');
      } else {
        headerEl.classList.add('site-header--hidden');
      }

      lastScrollY = currentScrollY;
    }

    function requestUpdate() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateHeaderVisibility);
    }

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });

    if (typeof mobileQuery.addEventListener === 'function') {
      mobileQuery.addEventListener('change', requestUpdate);
    } else if (typeof mobileQuery.addListener === 'function') {
      mobileQuery.addListener(requestUpdate);
    }

    requestUpdate();
  }

  document.addEventListener('astro:page-load', initAutoHideHeader);

  function initBrandMarkHover() {
    const brand = document.querySelector('.site-brand');
    const mark = document.querySelector<HTMLElement>('.brand-mark');
    if (!brand || !mark) return;

    const stripes = Array.from(mark.querySelectorAll<HTMLElement>('.brand-mark-stripe'));
    const step = 0.025;
    let controller: AbortController | null = null;
    let activeAnimations: Animation[] = [];

    function randomOrder(count: number): number[] {
      const order = Array.from({ length: count }, (_, i) => i);
      for (let i = order.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [order[i], order[j]] = [order[j], order[i]];
      }
      return order;
    }

    function cancelAll() {
      if (controller) controller.abort();
      controller = new AbortController();
      activeAnimations.forEach(a => a.cancel());
      activeAnimations = [];
    }

    function resetStripes() {
      stripes.forEach(s => {
        s.style.animation = 'none';
        s.style.transform = '';
        s.style.opacity = '';
      });
    }

    brand.addEventListener('mouseenter', () => {
      cancelAll();

      resetStripes();
      mark.offsetHeight; // reflow

      mark.classList.remove('brand-mark--leaving');
      mark.classList.add('brand-mark--entering');

      const order = randomOrder(stripes.length);
      stripes.forEach((s, idx) => {
        s.style.animation = `stripe-slide-in 0.18s ease-out ${order[idx] * step}s both`;
      });
    });

    brand.addEventListener('mouseleave', () => {
      cancelAll();
      const signal = controller!.signal;

      mark.classList.remove('brand-mark--entering');
      mark.classList.add('brand-mark--leaving');

      // Snapshot each stripe's current transform and opacity
      const snapshots = stripes.map(s => {
        const cs = getComputedStyle(s);
        const opacity = parseFloat(cs.opacity);
        const matrix = cs.transform;
        let ty = 0;
        if (matrix && matrix !== 'none') {
          const parts = matrix.match(/matrix.*\((.+)\)/);
          if (parts) {
            const values = parts[1].split(',').map(Number);
            ty = values.length === 6 ? values[5] : values[13] || 0;
          }
        }
        return { opacity, ty };
      });

      resetStripes();

      const visibleIndices = snapshots.reduce<number[]>((acc, snap, i) => {
        if (snap.opacity > 0.05) acc.push(i);
        return acc;
      }, []);

      if (visibleIndices.length === 0) {
        mark.classList.remove('brand-mark--leaving');
        return;
      }

      let finished = 0;
      const order = randomOrder(visibleIndices.length);

      visibleIndices.forEach((stripeIdx, orderIdx) => {
        const s = stripes[stripeIdx];
        const snap = snapshots[stripeIdx];
        const height = s.parentElement?.offsetHeight || 40;

        // Animate from current position down and out with random stagger
        const anim = s.animate([
          { transform: `translateY(${snap.ty}px)`, opacity: snap.opacity },
          { transform: `translateY(${height * 1.1}px)`, opacity: 0 }
        ], {
          duration: 160,
          delay: order[orderIdx] * 25,
          easing: 'ease-in',
          fill: 'both'
        });

        activeAnimations.push(anim);

        anim.addEventListener('finish', () => {
          anim.cancel();
          finished++;
          if (finished >= visibleIndices.length) {
            mark.classList.remove('brand-mark--leaving');
            resetStripes();
          }
        }, { once: true, signal });
      });
    });
  }

  document.addEventListener('astro:page-load', initBrandMarkHover);
</script>