---
---
<div class="theme-control" data-theme-control>
  <div class="theme-toggle-shell">
    <button
      class="theme-toggle"
      type="button"
      aria-label="Toggle color theme"
      aria-expanded="false"
      aria-pressed="false"
    >
      <svg width="24px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path class="sun" fill-rule="evenodd"
              d="M12 17.5a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zm0 1.5a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm12-7a.8.8 0 0 1-.8.8h-2.4a.8.8 0 0 1 0-1.6h2.4a.8.8 0 0 1 .8.8zM4 12a.8.8 0 0 1-.8.8H.8a.8.8 0 0 1 0-1.6h2.5a.8.8 0 0 1 .8.8zm16.5-8.5a.8.8 0 0 1 0 1l-1.8 1.8a.8.8 0 0 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM6.3 17.7a.8.8 0 0 1 0 1l-1.7 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM12 0a.8.8 0 0 1 .8.8v2.5a.8.8 0 0 1-1.6 0V.8A.8.8 0 0 1 12 0zm0 20a.8.8 0 0 1 .8.8v2.4a.8.8 0 0 1-1.6 0v-2.4a.8.8 0 0 1 .8-.8zM3.5 3.5a.8.8 0 0 1 1 0l1.8 1.8a.8.8 0 1 1-1 1L3.5 4.6a.8.8 0 0 1 0-1zm14.2 14.2a.8.8 0 0 1 1 0l1.8 1.7a.8.8 0 0 1-1 1l-1.8-1.7a.8.8 0 0 1 0-1z" />
        <path class="moon" fill-rule="evenodd"
              d="M16.5 6A10.5 10.5 0 0 1 4.7 16.4 8.5 8.5 0 1 0 16.4 4.7l.1 1.3zm-1.7-2a9 9 0 0 1 .2 2 9 9 0 0 1-11 8.8 9.4 9.4 0 0 1-.8-.3c-.4 0-.8.3-.7.7a10 10 0 0 0 .3.8 10 10 0 0 0 9.2 6 10 10 0 0 0 4-19.2 9.7 9.7 0 0 0-.9-.3c-.3-.1-.7.3-.6.7a9 9 0 0 1 .3.8z" />
      </svg>
    </button>

    <div class="theme-confirm-inline" aria-hidden="true">
      <span class="theme-confirm-text">Save theme?</span>
      <div class="theme-consent-actions">
        <button type="button" class="theme-consent-confirm">Yes</button>
        <button type="button" class="theme-consent-cancel">No</button>
      </div>
    </div>
  </div>
</div>

<style>
  .theme-control {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    }

    .theme-toggle-shell {
    display: grid;
    grid-template-columns: 2.7rem 0fr;
    align-items: center;
    gap: 0;
    font-family: var(--font-condensed);
    min-width: 0;
    max-width: 2.7rem;
    overflow: clip;
    border-radius: 0.45rem;
    border: 1px solid transparent;
    background: transparent;
    transition: grid-template-columns 0.24s ease, max-width 0.24s ease, background-color 0.2s ease, border-color 0.2s ease;
    }

    .theme-control[data-confirming="true"] .theme-toggle-shell {
    grid-template-columns: 2.7rem 1fr;
    max-width: min(19rem, calc(100vw - 2rem));
    border-color: color-mix(in srgb, var(--color-border) 86%, black 14%);
    background: color-mix(in srgb, var(--color-bg) 96%, #eadfce 4%);
    }

    :global(.dark) .theme-control[data-confirming="true"] .theme-toggle-shell {
    background: color-mix(in srgb, var(--color-bg) 90%, white 10%);
  }

    .theme-toggle {
      border: 0;
      background: none;
      cursor: pointer;
      padding: 0.35rem;
      border-radius: 0.32rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      opacity: 0.7;
      flex: 0 0 auto;
      width: 2.7rem;
      transition: background-color 0.15s ease, opacity 0.15s ease;
    }

    .theme-toggle:hover {
      opacity: 1;
      background-color: rgba(0, 0, 0, 0.06);
    }

    :global(.dark) .theme-toggle:hover {
      background-color: rgba(255, 255, 255, 0.1);
    }

    .sun {
      fill: transparent;
    }

    .moon {
      fill: black;
    }

    :global(.dark) .sun {
      fill: white;
    }

    :global(.dark) .moon {
      fill: transparent;
    }

    .theme-confirm-inline {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
      padding: 0.18rem 0.3rem 0.18rem 0;
      white-space: nowrap;
      opacity: 0;
      overflow: hidden;
      pointer-events: none;
      transform: translateX(-0.18rem);
      transition: opacity 0.16s ease, transform 0.22s ease;
    }

    .theme-control[data-confirming="true"] .theme-confirm-inline {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
    }

    .theme-confirm-text {
      font-family: var(--font-condensed);
      font-size: 0.8rem;
      line-height: 1.2;
      letter-spacing: 0.01em;
    }

    .theme-consent-actions {
      display: inline-flex;
      gap: 0.4rem;
      align-items: center;
      padding-left: 0.45rem;
      border-left: 1px solid color-mix(in srgb, var(--color-border) 75%, transparent);
      flex: 0 0 auto;
    }

    .theme-consent-confirm,
    .theme-consent-cancel {
      border: 1px solid color-mix(in srgb, var(--color-border) 82%, black 18%);
      background: color-mix(in srgb, var(--color-bg) 93%, #e7dccb 7%);
      color: inherit;
      cursor: pointer;
      padding: 0.3rem 0.48rem;
      border-radius: 0.22rem;
      font-family: var(--font-condensed);
      font-size: 0.72rem;
      line-height: 1;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .theme-consent-confirm:hover,
    .theme-consent-cancel:hover {
      background: color-mix(in srgb, var(--color-link) 9%, var(--color-bg) 91%);
    }

    :global(.dark) .theme-consent-confirm,
    :global(.dark) .theme-consent-cancel {
      background: color-mix(in srgb, var(--color-bg) 78%, white 22%);
    }

    :global(.dark) .theme-toggle-shell {
      background: transparent;
      border-color: transparent;
    }

    @media (max-width: 800px) {
    .theme-control {
      display: flex;
      width: 100%;
    }

    .theme-toggle-shell {
      max-width: 2.7rem;
    }

    .theme-control[data-confirming="true"] .theme-toggle-shell {
      grid-template-columns: 2.7rem 1fr;
      width: 100%;
      max-width: none;
    }

    .theme-confirm-inline {
      flex: 1 1 auto;
      justify-content: space-between;
      padding-right: 0.4rem;
    }

    .theme-confirm-text {
      white-space: normal;
      max-width: 8rem;
    }
    }
</style>
