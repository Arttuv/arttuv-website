---
import { DEFAULT_COLOR } from "../config/colors";

interface Props {
  tagColor?: string;
}
const { tagColor = DEFAULT_COLOR } = Astro.props;
---
<div class="reading-progress-container" id="reading-progress" style={`--tag-color: ${tagColor}`} aria-hidden="true">
  <div class="reading-progress-inner">
    <span class="reading-progress-heading" id="reading-progress-heading">
      <a class="reading-progress-title" id="reading-progress-title" href="#"></a>
      <span class="reading-progress-sep" id="reading-progress-sep"></span>
      <a class="reading-progress-section" id="reading-progress-section" href="#"></a>
    </span>
  </div>
  <div class="reading-progress-bar">
    <div class="reading-progress-fill" id="reading-progress-fill"></div>
  </div>
</div>

<script>
  function initReadingProgress() {
    const container = document.getElementById('reading-progress');
    const fill = document.getElementById('reading-progress-fill');
    const headingEl = document.getElementById('reading-progress-heading');
    const article = document.querySelector('.blog-post');

    if (!container || !fill || !headingEl || !article) return;

    const postBody = article.querySelector('.post-body');
    if (!postBody) return;

    // Collect h2 headings inside post body for section tracking
    const headings = Array.from(postBody.querySelectorAll('h2'));

    // Get the article h1 to know when to show the bar
    const articleH1 = article.querySelector('h1');
    if (!articleH1) return;

    let ticking = false;

    function getHeaderHeight() {
      const header = document.querySelector('header');
      return header ? header.getBoundingClientRect().height : 0;
    }

    function update() {
      ticking = false;

      // Position below the sticky header
      container.style.top = `${getHeaderHeight()}px`;

      const articleRect = article.getBoundingClientRect();
      const articleTop = window.scrollY + articleRect.top;
      const articleHeight = article.scrollHeight;
      const viewportHeight = window.innerHeight;

      // Progress: 0 at top of article, 1 when bottom of article is at bottom of viewport
      const scrolled = window.scrollY - articleTop;
      const total = articleHeight - viewportHeight;
      const progress = Math.min(1, Math.max(0, scrolled / total));

      fill.style.width = `${progress * 100}%`;

      // Show/hide: visible once scrolled past the h1
      const h1Bottom = articleH1.getBoundingClientRect().bottom;
      const headerH = getHeaderHeight();
      if (h1Bottom < headerH) {
        container.classList.add('visible');
      } else {
        container.classList.remove('visible');
      }

      // Find current section heading
      const titleEl = document.getElementById('reading-progress-title');
      const sepEl = document.getElementById('reading-progress-sep');
      const sectionEl = document.getElementById('reading-progress-section');
      if (!titleEl || !sepEl || !sectionEl) return;

      titleEl.textContent = articleH1.textContent || '';

      let currentSection = '';
      let currentId = '';
      const threshold = headerH + container.offsetHeight;
      for (let i = headings.length - 1; i >= 0; i--) {
        const rect = headings[i].getBoundingClientRect();
        if (rect.top <= threshold) {
          currentSection = headings[i].textContent || '';
          currentId = headings[i].id || '';
          break;
        }
      }
      sectionEl.textContent = currentSection;
      sectionEl.href = currentId ? `#${currentId}` : '#';
      sepEl.textContent = currentSection ? '›' : '';
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  // Run on initial load and on Astro page transitions
  document.addEventListener('astro:page-load', initReadingProgress);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReadingProgress);
  } else {
    initReadingProgress();
  }
</script>

<style is:global>
  .reading-progress-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 8;
    opacity: 0;
    transform: translateY(-100%);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  .reading-progress-container.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .reading-progress-inner {
    background: #fffbf8;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding: 0.3rem 1rem;
    display: flex;
    align-items: center;
    min-height: 1.6rem;
  }

  .dark .reading-progress-inner {
    background: #000;
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .reading-progress-heading {
    font-family: var(--font-condensed);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 70ch;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .reading-progress-title {
    color: #444;
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
  }

  .reading-progress-title:hover {
    text-decoration: underline;
  }

  .dark .reading-progress-title {
    color: #bbb;
  }

  .reading-progress-sep {
    color: #999;
    flex-shrink: 0;
  }

  .dark .reading-progress-sep {
    color: #666;
  }

  .reading-progress-section {
    color: var(--tag-color, #212121);
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 600;
    text-decoration: none;
  }

  .reading-progress-section:hover {
    text-decoration: underline;
  }

  .dark .reading-progress-section {
    color: var(--tag-color, #F5F5F5);
  }

  .reading-progress-bar {
    height: 2px;
    background: rgba(0, 0, 0, 0.06);
    width: 100%;
  }

  .dark .reading-progress-bar {
    background: rgba(255, 255, 255, 0.06);
  }

  .reading-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--tag-color, #212121);
    transition: width 0.1s linear;
  }
</style>
