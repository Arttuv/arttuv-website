---
import HeaderLink from "./HeaderLink.astro"
import SocialLinks from "./SocialLinks.astro"
import ThemeIcon from "./ThemeIcon.astro"
---
<div class="menu-wrapper">
  <div class="mobile-menu">
        <a href="/" class="menu-home" aria-label="Go to homepage">
            <span class="menu-brand-mark" aria-hidden="true"><span class="menu-brand-mark-text">AV</span></span>
            <span class="menu-brand-text">arttuv.com</span>
        </a>
    <button class="menu-toggle" aria-label="Toggle flyout menu" aria-expanded="false"
            aria-controls="flyout-menu"></button>

    <div class="menu-flyout" id="flyout-menu">
            <div class="menu-brand-intro">
                <p class="menu-intro-name">Arttu Viljakainen</p>
                <p class="menu-intro-tagline">A nordic approach to software, systems and people</p>
                <div class="menu-rainbow-bar" aria-hidden="true">
                    <span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
            </div>
            <nav class="menu-main">
        <HeaderLink href="/">Home</HeaderLink>
                <HeaderLink href="/writings/">Writings</HeaderLink>
                <HeaderLink href="/author/">Author</HeaderLink>
      </nav>
      <div class="menu-footer">
        <div class="menu-controls" role="button" tabindex="0">
          <ThemeIcon />
          <span class="menu-controls-label">Theme</span>
        </div>
        <nav class="menu-cta">
          <SocialLinks size="26px" showLabels />
        </nav>
      </div>
    </div>
  </div>
</div>

<style is:global>

    .menu-wrapper {
        display: none;
    }

    .mobile-menu {
        display: none;
        padding: 0.5rem 0;
        margin: 0 0.5rem;
        width: 100%;
    }

    @media screen and (max-width: 768px) {

        .mobile-menu a {
            color: inherit;
        }

        .menu-home {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            line-height: 1;
            font-family: var(--font-condensed);
        }

        .menu-brand-mark {
            display: inline-grid;
            place-items: center;
            position: relative;
            overflow: hidden;
            width: 2rem;
            height: 2rem;
            border: 2px solid currentColor;
            border-radius: 0.3rem;
            font-family: var(--font-condensed);
            font-size: 1rem;
            font-weight: 700;
            line-height: 1;
            text-align: center;
            letter-spacing: 0.01em;
            transition: border-color 0.22s ease;
        }

        .menu-brand-mark::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right,
                var(--color-red)    0%      16.67%,
                var(--color-orange) 16.67%  33.33%,
                var(--color-yellow) 33.33%  50%,
                var(--color-green)  50%     66.67%,
                var(--color-blue)   66.67%  83.33%,
                var(--color-purple) 83.33%  100%
            );
            transform: scaleX(0);
            transform-origin: right center;
            transition: transform 0.24s ease;
        }

        .menu-brand-mark-text {
            position: relative;
            z-index: 1;
            transition: color 0.22s ease;
        }

        .menu-home:hover .menu-brand-mark::before {
            transform: scaleX(1);
            transform-origin: left center;
        }

        .menu-home:hover .menu-brand-mark-text {
            color: #fff;
        }

        .menu-brand-text {
            font-family: var(--font-condensed);
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.02em;
        }

        .mobile-menu nav a {
            margin-bottom: 1rem;
        }

        .mobile-menu .menu-cta a {
            font-size: 1.5rem;
            text-decoration: underline;
        }

        /* === Menu Wrapper === */
        .menu-wrapper {
            align-items: center;
            color: black;
            display: flex;
            justify-content: space-between;
            padding:0;
        }

        .dark .menu-wrapper {
            background: black;
            color: white;
        }

        .menu-open .menu-flyout {
            transform: translateX(0);
        }

        .menu-wrapper a {
            align-items: center;
            color: inherit;
            display: flex;
            line-height: 1;
            transition: color var(--menu-trsdu) var(--menu-trstf);
            text-decoration: none;
        }

        .menu-wrapper a.active {
            text-decoration: underline;
        }

        /* === Flyout === */
        .menu-flyout {
            background: #fff7f4;
            color: black;
            display: flex;
            flex-direction: column;
            font-size: var(--menu-flyout-fz, 150%);
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            justify-content: space-between;
            padding: var(--menu-flyout-p, 4ch 2ch 2ch);
            position: fixed;
            transition: transform var(--menu-trsdu) var(--menu-trstf);
            transform: translateX(-100%);
            z-index: 1000;
            overflow: hidden;
        }

        .menu-flyout::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(120% 60% at 5% 0%, rgba(224, 58, 62, 0.08), transparent 60%),
                radial-gradient(90% 55% at 95% 8%, rgba(0, 157, 220, 0.08), transparent 65%),
                linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
            pointer-events: none;
            z-index: 0;
        }

        .menu-flyout > * {
            position: relative;
            z-index: 1;
        }

        .dark .menu-flyout {
            background: black;
            color: white;
        }

        .dark .menu-flyout::before {
            background:
                radial-gradient(120% 60% at 5% 0%, rgba(224, 58, 62, 0.12), transparent 60%),
                radial-gradient(90% 55% at 95% 8%, rgba(0, 157, 220, 0.12), transparent 65%),
                linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
        }

        .menu-brand-intro {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .menu-intro-name {
            margin: 0;
            font-family: var(--font-serif);
            font-size: clamp(1.4rem, 6.5vw, 1.95rem);
            line-height: 1.1;
            letter-spacing: 0.01em;
            animation: slideInUp 0.36s cubic-bezier(0.22, 1, 0.36, 1) 0.04s backwards;
        }

        .menu-intro-tagline {
            margin: 0;
            font-family: var(--font-condensed);
            font-size: 0.9rem;
            line-height: 1.35;
            letter-spacing: 0.02em;
            opacity: 0.8;
            max-width: 30ch;
            animation: slideInUp 0.36s cubic-bezier(0.22, 1, 0.36, 1) 0.08s backwards;
        }

        .menu-rainbow-bar {
            display: grid;
            grid-template-columns: repeat(6, minmax(0, 1fr));
            width: min(20rem, 85%);
            height: 10px;
            border-radius: 999px;
            overflow: hidden;
            margin-top: 0.25rem;
            animation: slideInUp 0.36s cubic-bezier(0.22, 1, 0.36, 1) 0.12s backwards;
        }

        .menu-rainbow-bar span:nth-child(1) { background: var(--color-red); transition: flex 0.2s ease; }
        .menu-rainbow-bar span:nth-child(2) { background: var(--color-orange); }
        .menu-rainbow-bar span:nth-child(3) { background: var(--color-yellow); }
        .menu-rainbow-bar span:nth-child(4) { background: var(--color-green); }
        .menu-rainbow-bar span:nth-child(5) { background: var(--color-blue); }
        .menu-rainbow-bar span:nth-child(6) { background: var(--color-purple); }

        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* === Menus === */
        .menu-cta, .menu-main {
            display: flex;
            flex: 1;
            flex-direction: var(--menu-flyout-dir, column);
        }

        .menu-cta {
            gap: clamp(0.5rem, -0.125rem + 2vw, 1rem);
            justify-content: end;
        }

        .menu-main {
            gap: clamp(0.5rem, -3.875rem + 14vw, 4rem);
        }

        /* === Menu Footer Controls === */
        .menu-footer {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid currentColor;
            opacity: 0.7;
        }

        .menu-controls {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.75rem;
            width: fit-content;
            cursor: pointer;
            padding: 0.5rem 0;
            margin: -0.5rem 0;
        }

        .menu-controls-label {
            font-family: var(--font-condensed);
            font-size: 0.95rem;
            font-weight: 500;
            letter-spacing: 0.01em;
            user-select: none;
        }

        .menu-toggle {
            color: black;
        }

        .dark .menu-toggle {
            color: white;
        }

        /* === Menu Toggle === */
        :where(.menu-toggle) {
            --menu-toggle-bdrs: 4px;
            --menu-toggle-gap: 8px;
            --menu-toggle-h: 2px;
            --menu-toggle-w: 24px;

            appearance: none;
            background: none;
            border: 0;
            display: grid;
            gap: var(--menu-toggle-gap);
            height: var(--menu-toggle-w);
            outline: none;
            place-content: center;
            z-index: 1001;
        }

        .menu-toggle::before,
        .menu-toggle::after {
            background-color: currentColor;
            border-radius: var(--menu-toggle-bdrs);
            content: "";
            height: var(--menu-toggle-h);
            transform-origin: center center;
            transition: transform var(--menu-trsdu) var(--menu-trstf);
            width: var(--menu-toggle-w);
        }

        .menu-open .menu-toggle {
            gap: 0;
        }

        .menu-open .menu-toggle::after {
            transform: translate(var(--menu-toggle-h), calc(var(--menu-toggle-h) / -2)) rotate(45deg);
        }

        .menu-open .menu-toggle::before {
            transform: translate(var(--menu-toggle-h), calc(var(--menu-toggle-h) / 2)) rotate(-45deg);
        }

        .menu-open .menu-brand-intro {
            animation: fadeIn 0.36s ease 0.16s backwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .icon, .icon-stroke {
            height: var(--icon-sz, 2em);
        }

        .icon-stroke {
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            stroke-width: 1;
            stroke: currentColor;
        }

        .mobile-menu a, .mobile-menu a:visited, .mobile-menu a:active {
            color: black;
        }

        .dark .mobile-menu a, .dark .mobile-menu a:visited, .dark .mobile-menu a:active {
            color: #F5F5F5;
        }

        .menu-wrapper {
            display: flex;
        }

        .mobile-menu {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    /* === Prevent Scrolling on <body>, when .menu-toggle is checked (flyout is visible) === */
    @media (max-width: 768px) {
        .menu-open {
            overflow: hidden;
        }
    }

    /* === Extra small screens === */
    @media (max-width: 360px) {
        .mobile-menu {
            margin: 0 0.25rem;
        }
        
        .menu-flyout {
            padding: var(--menu-flyout-p, 2ch 1ch 1ch);
        }
        
        .menu-brand-mark {
            width: 1.75rem;
            height: 1.75rem;
            font-size: 0.9rem;
        }

        .menu-brand-text {
            font-size: 0.85rem;
        }

            .menu-intro-name {
                font-size: clamp(1.3rem, 6vw, 1.6rem);
            }

            .menu-rainbow-bar {
                width: min(16rem, 75%);
                height: 8px;
            }
        }
    }

    @media (prefers-reduced-motion: no-preference) and (max-width: 768px) {
        .menu-open .menu-brand-intro {
            animation: fadeIn 0.36s ease 0.16s both;
        }
    }

</style>

<script is:inline>
  ;(function() {
    if (window.__mobileMenuInitialized) return
    window.__mobileMenuInitialized = true

    function closeMenu() {
      document.body.classList.remove("menu-open")
      var toggle = document.querySelector(".menu-toggle")
      toggle && toggle.setAttribute("aria-expanded", "false")
    }

    // Toggle menu — event delegation
    document.addEventListener("click", function(e) {
      var toggle = e.target.closest(".menu-toggle")
      if (!toggle) return
      if (document.body.classList.contains("menu-open")) {
        closeMenu()
      } else {
        document.body.classList.add("menu-open")
        toggle.setAttribute("aria-expanded", "true")
      }
    })

    // Close on Escape
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && document.body.classList.contains("menu-open")) {
        closeMenu()
        var toggle = document.querySelector(".menu-toggle")
        toggle && toggle.focus()
      }
    })

    // Close on background tap inside flyout (not on links or theme toggle)
    var flyout = document.getElementById("flyout-menu")
    flyout && flyout.addEventListener("click", function(e) {
                        if (e.target.closest("a, .theme-control, .menu-controls, .menu-brand-intro")) return
      closeMenu()
    })

    // Trap focus inside flyout when open
    document.addEventListener("keydown", function(e) {
      if (e.key !== "Tab" || !document.body.classList.contains("menu-open")) return
      var flyout = document.getElementById("flyout-menu")
      if (!flyout) return
      var focusable = flyout.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])')
      if (focusable.length === 0) return
      var first = focusable[0]
      var last = focusable[focusable.length - 1]
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault()
        last.focus()
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault()
        first.focus()
      }
    })

    // Theme controls click — forward to theme button
    document.addEventListener("click", function(e) {
      var control = e.target.closest(".menu-controls")
      if (!control || e.target.closest(".theme-toggle")) return // ignore direct button clicks
      var themeButton = control.querySelector(".theme-toggle")
      if (themeButton) {
        themeButton.click()
      }
    })

    // Theme controls keyboard support
    document.addEventListener("keydown", function(e) {
      if ((e.key === "Enter" || e.key === " ") && e.target.closest(".menu-controls")) {
        e.preventDefault()
        var themeButton = e.target.closest(".menu-controls").querySelector(".theme-toggle")
        if (themeButton) {
          themeButton.click()
        }
      }
    })
  })()
</script>
