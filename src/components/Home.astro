---
import { Image } from "astro:assets"
import arttu from "../images/arttuv-bw.jpeg"
import { getCollection } from "astro:content"
import Comment from "./Comment.astro"
import ArticleCard from "./ArticleCard.astro"
import BauhausDivider from "./BauhausDivider.astro"
import OrbitDivider from "./OrbitDivider.astro"
import { featuredGroups } from "../config/featured"
const comments = (await getCollection("comments")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const allWritings = (await getCollection("writings")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

// Build a lookup map for featured posts
const postMap = new Map(allWritings.map(p => [p.id, p]));

// Resolve groups: keep slug order from config
const resolvedGroups = featuredGroups.map(group => ({
  ...group,
  posts: group.slugs.map(s => postMap.get(s)).filter(Boolean),
}));

// Collect all featured slugs to exclude from "Latest"
const featuredSlugs = new Set(featuredGroups.flatMap(g => g.slugs));
const latestPosts = allWritings.filter(p => !featuredSlugs.has(p.id)).slice(0, 4);
---

<div class="home-page">
  <div class="welcome-container">

    <div class="main-content">
      {resolvedGroups.map((group, gi) => (
        <section class={`featured-group featured-group--${gi} display-panel`}>
          <div class="panel-header">
            <span class="panel-status"></span>
            <h2 class="panel-title">{group.title}</h2>
          </div>
          <p class="featured-group-desc">{group.description}</p>
          <div class="writing-listing">
            {group.posts.map((post, i) => (
              <ArticleCard post={post} featured={gi === 0 && i === 0} slim={i > 0 || gi > 0} />
            ))}
          </div>
        </section>
      ))}

      {latestPosts.length > 0 && (
        <section class={`featured-group featured-group--${resolvedGroups.length} display-panel`}>
          <div class="panel-header">
            <span class="panel-status"></span>
            <h2 class="panel-title">Latest</h2>
          </div>
          <div class="writing-listing">
            {latestPosts.map((post) => (
              <ArticleCard post={post} slim />
            ))}
          </div>
        </section>
      )}

      <span class="button-container">
        <a href="/writings/">All writings →</a>
      </span>

      <OrbitDivider seed="home-orbit" spacing="1.5rem" />

      <BauhausDivider seed="home-bio" height="60px" spacing="2rem" />

      <article class="author-bio">
        <div class="line-heading">
          <h2>Arttu Viljakainen</h2>
        </div>
        <p>
          At the moment I'm a software development consultant.
        </p>
        <div class="article-card-text">
          <p>I've been coding for a living for 15 years, and writing code for some 20 years. I intend to keep on doing
            that.</p>
          <p>
            Teams are essential in creating software: combining interdisciplinary skills in a way that makes the whole
            more than the sum of each individual requires intentional effort.
            These days, most things worth doing require a team. Skills and viewpoints needed are just too diverse for
            any individual.
          </p>
          <p>
            I intend to study teams and get better at making exceptional teams emerge.
          </p>
          <p>
            Software happens in a complex world, in which you can't predict the future. That's why we have agile (<a
            href="/writings/agile-still-relevant/">which is still relevant, by the way</a>). I think it is
            essential to understand the difference between complicated and complex environments, and act accordingly.
            Agile never looks the same, and how to make it work is both interesting and rewarding.
          </p>
          <h3>I'm a generalist</h3>
          <p>
            Coding got me to the field of software development, but I may have stayed because of the people stuff.
          </p>
          <p>
            I'm increasingly interested in the human side of software development. Issues in projects are rarely related
            to technology, but on how to work productively and sustainably as a team, and on how to choose what to build
            next.
          </p>
          <p>
            Be it coding, teamwork, or processes, I feel like I have a lot to learn. I'm still excited about it.
          </p>
        </div>
        <div class="article-card-footer">
          <a class="read-more" href="/author/">Read more about the author →</a>
        </div>
      </article>
    </div>

    <aside class="author-sidebar">
      <div class="sidebar-panel">
        <div class="panel-header">
          <span class="panel-status"></span>
          <span class="panel-title">Author</span>
        </div>
        <div class="sidebar-photo-container">
          <a href="/author/" class="sidebar-photo-link">
            <div class="photo-reveal">
              <div class="photo-reveal-front">
                <Image src={arttu} alt="Arttu" loading="eager" />
              </div>
              <div class="photo-reveal-back">
                <span>This is Arttu, read more about them here →</span>
              </div>
            </div>
          </a>
          <button class="photo-reveal-toggle" type="button" aria-label="Show info">↻</button>
        </div>
        <span class="crew-name">Arttu</span>
        <span class="crew-role">Developer · Helsinki</span>
        <div class="crew-map" aria-label="Map showing Helsinki, Finland">
          <div class="map-viewport">
            <div class="helsinki-beacon">
              <span class="beacon-ping"></span>
              <span class="beacon-dot"></span>
            </div>
            <span class="beacon-label">HEL</span>
          </div>
          <span class="beacon-coords">60.17°N 24.94°E</span>
        </div>
        <p class="from-eu-with-love">🇪🇺 🇫🇮 ❤️ 🏳️‍🌈</p>
      </div>
      <div class="sidebar-panel">
        <div class="panel-header">
          <span class="panel-status"></span>
          <span class="panel-title">Comms</span>
        </div>
        <section class="feed-area">
          <div class="comment-listing">
            <ul>
              {comments.slice(0, 2).map(comment => (
                <li>
                  <Comment {comment} />
                </li>
              ))}
            </ul>
            <a class="feed-more" href="https://mastodon.social/@arttuv">More →</a>
          </div>
        </section>
      </div>
    </aside>

  </div>
</div>

<style>
    .home-page {
        width: 100%;
        margin: auto;
        margin-top: 1.5rem;
    }

    .welcome-container {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: 2rem;
        width: 100%;
    }

    .main-content {
        flex: 1;
        min-width: 0;
    }

    .author-sidebar {
        width: 180px;
        flex-shrink: 0;
        top: 5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }

    .sidebar-panel {
        border: 1px solid var(--color-border);
        border-radius: 0.25rem;
        padding: 0.5rem;
        width: 100%;
        position: relative;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .sidebar-panel::before,
    .sidebar-panel::after {
        content: '';
        position: absolute;
        width: 8px;
        height: 8px;
        border-color: var(--color-muted);
        border-style: solid;
        pointer-events: none;
    }

    .sidebar-panel::before {
        top: -1px;
        left: -1px;
        border-width: 2px 0 0 2px;
        border-radius: 2px 0 0 0;
    }

    .sidebar-panel .panel-header {
        align-self: flex-start;
    }

    .sidebar-panel .feed-area {
        align-self: stretch;
    }

    .sidebar-panel::after {
        bottom: -1px;
        right: -1px;
        border-width: 0 2px 2px 0;
        border-radius: 0 0 2px 0;
    }

    .crew-name {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 500;
        text-align: center;
        margin-top: 0.5rem;
        letter-spacing: 0.02em;
    }

    .crew-role {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--color-muted);
        text-align: center;
        letter-spacing: 0.03em;
        margin-top: 0.1rem;
    }

    .crew-map {
        width: 100%;
        margin-top: 0.4rem;
    }

    .map-viewport {
        width: 100%;
        aspect-ratio: 5 / 4;
        background: url('/europe-borders.svg') no-repeat;
        background-size: 280%;
        background-position: 72% 30%;
        position: relative;
        border-radius: 0.25rem;
        opacity: 0.5;
        transition: opacity 0.4s ease;
    }

    .map-viewport:hover {
        opacity: 0.8;
    }

    .dark .map-viewport {
        filter: invert(1);
        opacity: 0.4;
    }

    .dark .map-viewport:hover {
        opacity: 0.6;
    }

    /* Helsinki beacon - positioned relative to the visible viewport */
    .helsinki-beacon {
        position: absolute;
        top: 50%;
        left: 60%;
        transform: translate(-50%, -50%);
        width: 12px;
        height: 12px;
    }

    .beacon-dot {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--color-red);
    }

    .beacon-ping {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 5px;
        height: 5px;
        border-radius: 50%;
        border: 2px solid var(--color-red);
        animation: beaconPing 3s ease-out infinite;
    }

    @keyframes beaconPing {
        0%   { width: 5px; height: 5px; opacity: 0.8; }
        70%  { width: 20px; height: 20px; opacity: 0; }
        100% { width: 20px; height: 20px; opacity: 0; }
    }

    .beacon-label {
        position: absolute;
        top: 42%;
        left: 63%;
        font-family: var(--font-mono);
        font-size: 0.5rem;
        color: var(--color-red);
        letter-spacing: 0.05em;
        opacity: 0.8;
    }

    .beacon-coords {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.5rem;
        color: var(--color-muted);
        text-align: center;
        letter-spacing: 0.04em;
        margin-top: 0.2rem;
    }

    @media (prefers-reduced-motion: reduce) {
        .beacon-ping {
            animation: none;
        }
    }

    .sidebar-photo-container {
        position: relative;
        width: 100%;
    }

    .sidebar-photo-link {
        display: block;
        border-radius: 0.5rem;
        text-decoration: none;
    }

    .photo-reveal {
        position: relative;
        width: 100%;
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .photo-reveal-front {
        display: block;
    }

    .photo-reveal-front img {
        width: 100%;
        height: auto;
        display: block;
        border: 1px solid lightgray;
        border-radius: 0.5rem;
        transition: opacity 0.4s ease, filter 0.4s ease;
    }

    .photo-reveal-back {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 1rem;
        background: linear-gradient(135deg, var(--color-red) 0%, var(--color-orange) 20%, var(--color-yellow) 40%, var(--color-green) 60%, var(--color-blue) 80%, var(--color-purple) 100%);
        color: #fff;
        font-family: var(--font-condensed);
        font-size: 0.8rem;
        letter-spacing: 0.03em;
        border-radius: 0.5rem;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .sidebar-photo-link:hover .photo-reveal-front img,
    .photo-reveal.revealed .photo-reveal-front img {
        opacity: 0;
        filter: blur(2px);
    }

    .sidebar-photo-link:hover .photo-reveal-back,
    .photo-reveal.revealed .photo-reveal-back {
        opacity: 1;
    }

    .photo-reveal-toggle {
        display: none;
    }

    .from-eu-with-love {
        font-weight: 200;
        font-size: 0.9rem;
        margin-top: 0.35rem;
        margin-bottom: 0;
        text-align: center;
    }

    .feed-area {
        margin-top: 0.25rem;
        width: 100%;
    }

    .comment-listing ul {
        list-style-type: none;
        padding-left: 0;
        margin-top: 0;
    }

    .comment-listing li {
        margin-bottom: 0.75rem;
    }

    .feed-more {
        font-family: var(--font-condensed);
        font-size: 0.75rem;
        color: #999;
        text-decoration: none;
        display: block;
        text-align: right;
    }

    .feed-more:hover {
        text-decoration: underline;
    }

    /* Compact overrides for feed inside narrow sidebar */
    :global(.author-sidebar .internal-comment) {
        padding: 0 0.25rem;
    }

    :global(.author-sidebar .embedded-mastodon-comment) {
      padding: 0.35rem 0.4rem 0.25rem;
    }

    @media (min-width: 801px) {
        :global(.author-sidebar .html-content) {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }

        :global(.author-sidebar .embedded-mastodon-comment .html-content) {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }

        :global(.author-sidebar .comment-content) {
            border-left: none;
            padding-left: 0;
        }

        :global(.dark .author-sidebar .comment-content) {
            border-left: none;
        }

        :global(.dark .author-sidebar .embedded-mastodon-comment .html-content) {
            border-left: none;
        }
    }

    :global(.author-sidebar .html-content p) {
        line-height: 1.7;
        margin-bottom: 0.25rem;
    }

    :global(.author-sidebar .comment-content) {
        font-size: 0.7rem;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    :global(.author-sidebar .embedded-mastodon-comment) {
        font-size: 0.7rem;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    .button-container {
        display: flex;
        justify-content: center;
        margin: 1rem 0;
    }

    .featured-group {
        margin-bottom: 2rem;
    }

    /* === Display panel (sci-fi bridge panel) === */
    .display-panel {
        border: 1px solid var(--color-border);
        border-radius: 0.25rem;
        padding: 1rem 1rem 0.75rem;
        position: relative;
        box-sizing: border-box;
    }

    /* Corner bracket accents */
    .display-panel::before,
    .display-panel::after {
        content: '';
        position: absolute;
        width: 12px;
        height: 12px;
        border-color: var(--color-muted);
        border-style: solid;
        pointer-events: none;
    }

    .display-panel::before {
        top: -1px;
        left: -1px;
        border-width: 2px 0 0 2px;
        border-radius: 2px 0 0 0;
    }

    .display-panel::after {
        bottom: -1px;
        right: -1px;
        border-width: 0 2px 2px 0;
        border-radius: 0 0 2px 0;
    }

    .panel-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.25rem;
    }

    .panel-status {
        display: inline-block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--color-green);
        flex-shrink: 0;
        box-shadow: 0 0 4px var(--color-green);
    }

    .panel-title {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-muted);
        margin: 0;
        line-height: 1;
    }

    .featured-group-desc {
        font-family: var(--font-condensed);
        font-size: 0.82rem;
        color: var(--color-muted);
        margin: 0 0 0.75rem;
        line-height: 1.5;
    }

    .author-bio {
        margin-top: 1rem;
        font-size: smaller;
    }

    .article-card-footer {
        text-align: right;
    }

    .article-card--slim h2 {
        font-size: 0.9rem;
    }

    @media (max-width: 800px) {
        .welcome-container {
            flex-direction: column;
        align-items: stretch;
            margin-top: 1rem;
        }

        /* On mobile, reorder so sidebar appears after the first group */
        .main-content {
            display: contents;
        }

        .featured-group--0  { order: 1; }
        .author-sidebar      { order: 2; }
        .featured-group--1  { order: 3; }
        .featured-group--2  { order: 4; }
        .featured-group--3  { order: 5; }
        .button-container    { order: 6; }
        :global(.orbit-divider)   { order: 7; }
        :global(.bauhaus-divider) { order: 8; }
        .author-bio          { order: 9; }

        .featured-group,
        .button-container,
        .author-bio,
        :global(.bauhaus-divider),
        :global(.orbit-divider) {
            width: 100%;
        }

        .author-sidebar {
            position: static;
            width: 100%;
            align-items: center;
            max-width: 100%;
        }

        .sidebar-panel {
            max-width: 50ch;
        }

        .author-sidebar img {
            max-width: 30ch;
            max-height: 50vh;
        }

        .sidebar-photo-container {
            max-width: 30ch;
        }

        .sidebar-photo-link {
            /* no perspective needed */
        }

        /* Disable hover reveal on mobile (use button/scroll instead) */
        .sidebar-photo-link:hover .photo-reveal-front img {
            opacity: 1;
            filter: none;
        }

        .sidebar-photo-link:hover .photo-reveal-back {
            opacity: 0;
        }

        .photo-reveal-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            right: -0.5rem;
            top: -0.5rem;
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            border: 1px solid lightgray;
            background: var(--color-bg);
            color: var(--color-muted);
            font-size: 1rem;
            cursor: pointer;
            z-index: 2;
            line-height: 1;
        }

        .feed-area {
            width: 100%;
            max-width: 50ch;
            text-align: left;
        }

        .comment-listing ul {
            width: 100%;
        }
    }
</style>

<script>
  function initPhotoReveal() {
    const container = document.querySelector('.sidebar-photo-container');
    const revealEl = document.querySelector('.photo-reveal');
    const toggleBtn = document.querySelector('.photo-reveal-toggle');
    if (!container || !revealEl || !toggleBtn) return;

    toggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      revealEl.classList.toggle('revealed');
    });

    if (window.innerWidth <= 800) {
      let manuallyToggled = false;

      toggleBtn.addEventListener('click', () => {
        manuallyToggled = !manuallyToggled;
      });

      function checkReveal() {
        if (manuallyToggled) return;
        const rect = container.getBoundingClientRect();
        const photoMiddle = rect.top + rect.height / 2;
        const screenCenter = window.innerHeight / 2;

        if (photoMiddle < screenCenter) {
          revealEl.classList.add('revealed');
        } else {
          revealEl.classList.remove('revealed');
        }
      }

      window.addEventListener('scroll', checkReveal, { passive: true });
      checkReveal();
    }
  }

  document.addEventListener('astro:page-load', initPhotoReveal);
</script>
