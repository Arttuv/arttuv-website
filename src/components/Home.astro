---
import { Image } from "astro:assets"
import arttu from "../images/arttuv-bw.jpeg"
import { getCollection } from "astro:content"
import Comment from "./Comment.astro"
import ArticleCard from "./ArticleCard.astro"
import BauhausDivider from "./BauhausDivider.astro"
const comments = (await getCollection("comments")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const writings = (await getCollection("writings")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<div class="home-page">
  <div class="welcome-container">

    <div class="main-content">
      <div class="writing-listing">
        {writings.slice(0, 5).map((post, index) => (
          <ArticleCard post={post} featured={index === 0} slim={index >= 3} />
        ))}
      </div>

      <span class="button-container">
        <a href="/writings/">All writings →</a>
      </span>

      <BauhausDivider seed="home-bio" height="60px" spacing="2rem" />

      <article class="author-bio">
        <div class="line-heading">
          <h2>Arttu Viljakainen</h2>
        </div>
        <p>
          At the moment I'm a software development consultant.
        </p>
        <div class="article-card-text">
          <p>I've been coding for a living for 15 years, and writing code for some 20 years. I intend to keep on doing
            that.</p>
          <p>
            Teams are essential in creating software: combining interdisciplinary skills in a way that makes the whole
            more than the sum of each individual requires intentional effort.
            These days, most things worth doing require a team. Skills and viewpoints needed are just too diverse for
            any individual.
          </p>
          <p>
            I intend to study teams and get better at making exceptional teams emerge.
          </p>
          <p>
            Software happens in a complex world, in which you can't predict the future. That's why we have agile (<a
            href="/writings/agile-still-relevant-in-2024">which is still relevant, by the way</a>). I think it is
            essential to understand the difference between complicated and complex environments, and act accordingly.
            Agile never looks the same, and how to make it work is both interesting and rewarding.
          </p>
          <h3>I'm a generalist</h3>
          <p>
            Coding got me to the field of software development, but I may have stayed because of the people stuff.
          </p>
          <p>
            I'm increasingly interested in the human side of software development. Issues in projects are rarely related
            to technology, but on how to work productively and sustainably as a team, and on how to choose what to build
            next.
          </p>
          <p>
            Be it coding, teamwork, or processes, I feel like I have a lot to learn. I'm still excited about it.
          </p>
        </div>
        <div class="article-card-footer">
          <a class="read-more" href="/author/">Read more about the author →</a>
        </div>
      </article>
    </div>

    <aside class="author-sidebar">
      <div class="sidebar-photo-container">
        <a href="/author/" class="sidebar-photo-link">
          <div class="photo-flip">
            <div class="photo-flip-front">
              <Image src={arttu} alt="Arttu" loading="eager" />
            </div>
            <div class="photo-flip-back">
              <span>This is Arttu, read more about them here →</span>
            </div>
          </div>
        </a>
        <button class="photo-flip-toggle" type="button" aria-label="Flip photo">↻</button>
      </div>
      <p class="from-eu-with-love">Code from 🇪🇺🇫🇮, writ... prompted with ❤️🏳️‍🌈</p>
      <section class="feed-area">
        <p class="feed-heading">Mastodon</p>
        <div class="comment-listing">
          <ul>
            {comments.slice(0, 2).map(comment => (
              <li>
                <Comment {comment} />
              </li>
            ))}
          </ul>
          <a class="feed-more" href="https://scholar.social/@arttuv">More →</a>
        </div>
      </section>
    </aside>

  </div>
</div>

<style>
    .home-page {
        width: 100%;
        margin: auto;
    }

    .welcome-container {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: 2rem;
        margin-top: 2rem;
        width: 100%;
    }

    .main-content {
        flex: 1;
        min-width: 0;
    }

    .author-sidebar {
        width: 160px;
        flex-shrink: 0;
        top: 5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .sidebar-photo-container {
        position: relative;
        width: 100%;
    }

    .sidebar-photo-link {
        display: block;
        border-radius: 0.5rem;
        perspective: 600px;
        text-decoration: none;
    }

    .photo-flip {
        position: relative;
        width: 100%;
        transition: transform 0.5s ease;
        transform-style: preserve-3d;
    }

    .sidebar-photo-link:hover .photo-flip {
        transform: rotateY(180deg);
    }

    .photo-flip.flipped {
        transform: rotateY(180deg);
    }

    .photo-flip-front,
    .photo-flip-back {
        backface-visibility: hidden;
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .photo-flip-front img {
        width: 100%;
        height: auto;
        display: block;
        border: 1px solid lightgray;
        border-radius: 0.5rem;
    }

    .photo-flip-back {
        position: absolute;
        inset: 0;
        transform: rotateY(180deg);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 1rem;
        background: linear-gradient(135deg, var(--color-red) 0%, var(--color-blue) 50%, var(--color-yellow) 100%);
        color: #fff;
        font-family: var(--font-condensed);
        font-size: 0.8rem;
        letter-spacing: 0.03em;
    }

    .photo-flip-toggle {
        display: none;
    }

    .from-eu-with-love {
        font-weight: 200;
        font-size: smaller;
        margin-top: 0.75rem;
        text-align: center;
    }

    .feed-area {
        margin-top: 1.5rem;
        width: 100%;
    }

    .feed-heading {
        font-family: var(--font-condensed);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #999;
        margin-bottom: 0.5rem;
    }

    .comment-listing ul {
        list-style-type: none;
        padding-left: 0;
        margin-top: 0;
    }

    .comment-listing li {
        margin-bottom: 0.75rem;
    }

    .feed-more {
        font-family: var(--font-condensed);
        font-size: 0.75rem;
        color: #999;
        text-decoration: none;
        display: block;
        text-align: right;
    }

    .feed-more:hover {
        text-decoration: underline;
    }

    /* Compact overrides for feed inside narrow sidebar */
    :global(.author-sidebar .internal-comment) {
        padding: 0 0.25rem;
    }

    :global(.author-sidebar .embedded-mastodon-comment) {
      padding: 0.35rem 0.4rem 0.25rem;
    }

    @media (min-width: 801px) {
        :global(.author-sidebar .html-content) {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }

        :global(.author-sidebar .embedded-mastodon-comment .html-content) {
            border-left: none;
            padding-left: 0;
            margin-left: 0;
        }

        :global(.author-sidebar .comment-content) {
            border-left: none;
            padding-left: 0;
        }

        :global(.dark .author-sidebar .comment-content) {
            border-left: none;
        }

        :global(.dark .author-sidebar .embedded-mastodon-comment .html-content) {
            border-left: none;
        }
    }

    :global(.author-sidebar .html-content p) {
        line-height: 1.7;
        margin-bottom: 0.25rem;
    }

    :global(.author-sidebar .comment-content) {
        font-size: 0.7rem;
    }

    :global(.author-sidebar .embedded-mastodon-comment) {
        font-size: 0.7rem;
    }

    .button-container {
        display: flex;
        justify-content: center;
        margin: 1rem 0;
    }

    .author-bio {
        margin-top: 1rem;
        font-size: smaller;
    }

    .article-card-footer {
        text-align: right;
    }

    .article-card--slim h2 {
        font-size: 0.9rem;
    }

    @media (max-width: 800px) {
        .welcome-container {
            flex-direction: column;
            margin-top: 1rem;
        }

        .author-sidebar {
            position: static;
            width: 100%;
            align-items: center;
        }

        .author-sidebar img {
            max-width: 30ch;
            max-height: 50vh;
        }

        .sidebar-photo-container {
            max-width: 30ch;
        }

        .sidebar-photo-link {
            perspective: 600px;
        }

        /* Disable hover flip on mobile */
        .sidebar-photo-link:hover .photo-flip {
            transform: none;
        }

        .photo-flip-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            right: -0.5rem;
            top: -0.5rem;
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            border: 1px solid lightgray;
            background: #fffbf8;
            color: #666;
            font-size: 1rem;
            cursor: pointer;
            z-index: 2;
            line-height: 1;
        }

        :global(.dark) .photo-flip-toggle {
            background: #111;
            color: #aaa;
            border-color: #444;
        }

        .feed-area {
            width: 100%;
            max-width: 50ch;
            text-align: left;
        }

        .comment-listing ul {
            width: 100%;
        }
    }
</style>

<script>
  function initPhotoFlip() {
    const container = document.querySelector('.sidebar-photo-container');
    const flipEl = document.querySelector('.photo-flip');
    const toggleBtn = document.querySelector('.photo-flip-toggle');
    if (!container || !flipEl || !toggleBtn) return;

    // Toggle button flips the card
    toggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      flipEl.classList.toggle('flipped');
    });

    // Auto-flip on scroll (mobile only)
    if (window.innerWidth <= 800) {
      let manuallyFlipped = false;

      toggleBtn.addEventListener('click', () => {
        manuallyFlipped = !manuallyFlipped;
      });

      function checkFlip() {
        if (manuallyFlipped) return;
        const rect = container.getBoundingClientRect();
        const photoMiddle = rect.top + rect.height / 2;
        const screenCenter = window.innerHeight / 2;

        if (photoMiddle < screenCenter) {
          flipEl.classList.add('flipped');
        } else {
          flipEl.classList.remove('flipped');
        }
      }

      window.addEventListener('scroll', checkFlip, { passive: true });
      checkFlip();
    }
  }

  document.addEventListener('astro:page-load', initPhotoFlip);
</script>
