---
import { Image } from "astro:assets"
import arttu from "../images/arttuv-bw.jpeg"
import { getCollection } from "astro:content"
import Comment from "./Comment.astro"
import FormattedDate from "../components/FormattedDate.astro"
import BauhausBlock from "./BauhausBlock.astro"
const comments = (await getCollection("comments")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const writings = (await getCollection("writings")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const tagColorMap: Record<string, string> = {
  'hci': '#1565C0',
  'dev': '#C62828',
  'research': '#F9A825',
};
---

<div class="home-page">
  <div class="welcome-container">

    <div class="main-content">
      <div class="writing-listing">
        {writings.slice(0, 5).map((post, index) => {
          const cardColor = post.data.tags?.[0] ? (tagColorMap[post.data.tags[0]] ?? '#212121') : '#212121';
          const isSlim = index >= 3;
          const cardClass = `article-card${index === 0 ? ' article-card--featured' : ''}${isSlim ? ' article-card--slim' : ''}`;
          return (
            <article class={cardClass} style={`--card-color: ${cardColor}`}>
              <BauhausBlock slug={post.slug} tags={post.data.tags} direction={index === 0 ? 'horizontal' : 'vertical'} />
              <div class="article-card-content">
                <div class="article-card-header">
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="card-tags">
                      {post.data.tags.map(tag => (
                        <a href={`/tags/${tag}`} class="card-tag" style={`color: ${tagColorMap[tag] ?? '#212121'}`}>#{tag}</a>
                      ))}
                    </div>
                  )}
                  <h2><a href={`/${post.collection}/${post.slug}/`}>{post.data.title}</a></h2>
                  <FormattedDate date={new Date(post.data.pubDate)} />
                </div>
                {!isSlim && (
                  <div class="article-card-text">
                    <p>{post.data.summary}</p>
                  </div>
                )}
                <div class="article-card-footer">
                  <a class="read-more" href={`/${post.collection}/${post.slug}/`}>Read more →</a>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <span class="button-container">
        <a href="/writings/">All writings →</a>
      </span>

      <article class="author-bio">
        <div class="line-heading">
          <h2>Arttu Viljakainen</h2>
        </div>
        <p>
          At the moment I'm a software development consultant.
        </p>
        <div class="article-card-text">
          <p>I've been coding for a living for 15 years, and writing code for some 20 years. I intend to keep on doing
            that.</p>
          <p>
            Teams are essential in creating software: combining interdisciplinary skills in a way that makes the whole
            more than the sum of each individual requires intentional effort.
            These days, most things worth doing require a team. Skills and viewpoints needed are just too diverse for
            any individual.
          </p>
          <p>
            I intend to study teams and get better at making exceptional teams emerge.
          </p>
          <p>
            Software happens in a complex world, in which you can't predict the future. That's why we have agile (<a
            href="/writings/agile-still-relevant-in-2024">which is still relevant, by the way</a>). I think it is
            essential to understand the difference between complicated and complex environments, and act accordingly.
            Agile never looks the same, and how to make it work is both interesting and rewarding.
          </p>
          <h3>I'm a generalist</h3>
          <p>
            Coding got me to the field of software development, but I may have stayed because of the people stuff.
          </p>
          <p>
            I'm increasingly interested in the human side of software development. Issues in projects are rarely related
            to technology, but on how to work productively and sustainably as a team, and on how to choose what to build
            next.
          </p>
          <p>
            Be it coding, teamwork, or processes, I feel like I have a lot to learn. I'm still excited about it.
          </p>
        </div>
        <div class="article-card-footer">
          <a class="read-more" href="/author/">Read more about the author →</a>
        </div>
      </article>
    </div>

    <aside class="author-sidebar">
      <Image src={arttu} alt="Arttu" loading="eager" />
      <p class="from-eu-with-love">Code from 🇪🇺🇫🇮 with ❤️&🏳️‍🌈</p>
      <section class="feed-area">
        <p class="feed-heading">Mastodon</p>
        <div class="comment-listing">
          <ul>
            {comments.slice(0, 2).map(comment => (
              <li>
                <Comment {comment} />
              </li>
            ))}
          </ul>
          <a class="feed-more" href="https://scholar.social/@arttuv">More →</a>
        </div>
      </section>
    </aside>

  </div>
</div>

<style>
    .home-page {
        width: 100%;
        margin: auto;
    }

    .welcome-container {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: 2rem;
        margin-top: 2rem;
        width: 100%;
    }

    .main-content {
        flex: 1;
        min-width: 0;
    }

    .author-sidebar {
        width: 190px;
        flex-shrink: 0;
        position: sticky;
        top: 5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .author-sidebar img {
        width: 100%;
        max-height: 40vh;
        object-fit: cover;
    }

    .from-eu-with-love {
        font-weight: 200;
        font-size: smaller;
        margin-top: 0.75rem;
        text-align: center;
    }

    .feed-area {
        margin-top: 1.5rem;
        width: 100%;
    }

    .feed-heading {
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #999;
        margin-bottom: 0.5rem;
    }

    .comment-listing ul {
        list-style-type: none;
        padding-left: 0;
        margin-top: 0;
    }

    .comment-listing li {
        margin-bottom: 0.75rem;
    }

    .feed-more {
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.75rem;
        color: #999;
        text-decoration: none;
        display: block;
        text-align: right;
    }

    .feed-more:hover {
        text-decoration: underline;
    }

    /* Compact overrides for feed inside narrow sidebar */
    :global(.author-sidebar .internal-comment) {
        padding: 0 0.25rem;
    }

    :global(.author-sidebar .embedded-mastodon-comment) {
        padding: 0.25rem 0 0 0;
    }

    :global(.author-sidebar .embedded-mastodon-details p) {
        margin-bottom: 0.25rem;
        line-height: 1.7;
    }

    :global(.author-sidebar .html-content p) {
        line-height: 1.7;
        margin-bottom: 0.25rem;
    }

    :global(.author-sidebar .comment-content) {
        font-size: 0.7rem;
    }

    :global(.author-sidebar .embedded-mastodon-comment) {
        font-size: 0.7rem;
    }

    .button-container {
        display: flex;
        justify-content: center;
        margin: 1rem 0;
    }

    .author-bio {
        margin-top: 1rem;
        font-size: smaller;
    }

    .article-card-footer {
        text-align: right;
    }

    .article-card--slim h2 {
        font-size: 0.9rem;
    }

    @media (max-width: 800px) {
        .welcome-container {
            flex-direction: column;
            margin-top: 1rem;
        }

        .author-sidebar {
            position: static;
            width: 100%;
            align-items: center;
        }

        .author-sidebar img {
            max-width: 30ch;
            max-height: 50vh;
        }

        .feed-area {
            width: 100%;
            max-width: 50ch;
            text-align: left;
        }

        .comment-listing ul {
            width: 100%;
        }
    }
</style>
