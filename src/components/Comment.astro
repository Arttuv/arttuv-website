---
import { getEntry, render, type CollectionEntry } from 'astro:content';
import MastodonEmbedded from './MastodonEmbedded.astro';
const { comment } = Astro.props;
const { Content } = await render(comment);
const internalLinkTarget = comment.data.internalLink
  ? (await getEntry(comment.data.internalLink)) as CollectionEntry<"writings">
  : null;
---

<div class="comment">
    {internalLinkTarget && !comment.data.mastodon && <div class="internal-comment-details">On <a href={`/${internalLinkTarget.collection}/${internalLinkTarget.id}`}>{internalLinkTarget.data.title}</a></div>}
    {comment.data.mastodon && <MastodonEmbedded statusId={comment.data.mastodon} />}
    <div class="internal-comment">
        <div class="comment-content">
            <Content />
        </div>
    </div>
</div>

<style>

    .internal-comment-details {
        font-size: small;
        margin: 1rem 0 0 2rem;
    }
    .internal-comment{
        padding:0 2rem 0 2rem;
    }
    .comment-content {
        font-size: smaller;
    }
    :global(.comment-content) {
        border-left: 1px solid black;
        padding-left: 1rem;
    }

    :global(.dark .comment-content) {
        border-left: 1px solid lightgray;
    }

    @media screen and (max-width: 600px) {
        .comment {
            padding: 1rem 0 1rem 0;
        }
    }
</style>