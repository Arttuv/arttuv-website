---
export interface Props {
  date: Date;
  time?: boolean;
}

const { date, time = false } = Astro.props

const datePart = date.toLocaleDateString("en-us", {
  year: "numeric",
  month: "short",
  day: "numeric",
})

const timePart = time
  ? date.toLocaleTimeString("en-GB", {
      hour: "2-digit",
      minute: "2-digit",
    })
  : null
---

<time class="telemetry-date" datetime={date.toISOString()}>
  {datePart}{timePart && <span class="telemetry-time"> · {timePart}</span>}
</time>

<style>
  .telemetry-date {
    font-family: var(--font-mono);
    font-size: 0.72em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
</style>
