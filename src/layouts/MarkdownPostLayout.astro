---
import BaseLayout from "./BaseLayout.astro"
import FormattedDate from "../components/FormattedDate.astro"
import Mastodon from "../components/Mastodon.astro"
import Comment from "../components/Comment.astro"
import BauhausBlock from "../components/BauhausBlock.astro"
import { getCollection, type CollectionEntry } from "astro:content"
type Props = CollectionEntry<"writings">;
const post = Astro.props

const tagColorMap: Record<string, string> = {
  'hci': '#1565C0',
  'dev': '#C62828',
  'research': '#F9A825',
};
const tagColor = post.data.tags?.[0] ? (tagColorMap[post.data.tags[0]] ?? '#212121') : '#212121';

const comments = (await getCollection("comments", (comment) => {
  return comment.data.internalLink?.id == post.id // TODO BETTER
})).sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()).filter((comment) => comment.data.mastodon !== post.data.mastodon)
---
<BaseLayout title={post.data.title} description={post.data.summary}>
  <article class="blog-post" style={`--tag-color: ${tagColor}`}>
    <div class="category">
      {post.data.tags.map((tag) => (
        <span><a href={`/tags/${tag}`}>#{tag}</a></span>
      ))}
    </div>
    <BauhausBlock slug={post.id} tags={post.data.tags} direction="horizontal" />
    <h1>{post.data.title}</h1>
    <FormattedDate date={new Date(post.data.pubDate)} />
    <hr />
    {comments.length > 0 && (
      <div class="writing-notes">
        {comments.map((comment) => (
          <Comment {comment} />
        ))}
      </div>
    )}
    <slot />
    <hr class="content-ending-line" />
    <div class="writing-ending">•</div>
    {post.data.mastodon &&
      <Mastodon statusId={post.data.mastodon} />}
  </article>
</BaseLayout>

<style is:global>
    .blog-post {
        max-width: 70ch;
        margin: 2rem auto;
    }

    .blog-post pre {
        overflow: scroll;
    }

    .writing-notes {
        margin: 1rem 2rem;
    }

    .blog-post h1, .blog-post h2, .blog-post h3, .blog-post h4, .blog-post h5 {
        padding-left:0;
        margin-left:0;
        padding-bottom:0;
        margin-top: 3rem;
        margin-bottom: 1rem;
    }

    .blog-post h1:first-of-type {
        font-size: 3rem;
        text-align: left;
        text-decoration: none;
        margin-left: 0px;
        padding-bottom:0;
        margin-top: 2rem;
        margin-bottom: 1.5rem;
        font-weight: 300;
    }

    .blog-post .category {
        text-transform: uppercase;
        font-weight: normal;
        font-size: 1rem;
        margin-bottom: 0.5rem;
        padding-bottom:0;
        padding-top: 0px;
        padding-left:0;
        margin-top: 1rem;
    }

    .blog-post time {
        display: block;
        font-family: 'Roboto Condensed Variable', sans-serif;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #666;
        margin-top: 0;
        margin-bottom: 1.5rem;
    }

    .dark .blog-post time {
        color: #aaa;
    }

    .blog-post hr:not(.content-ending-line) {
        border: none;
        border-top: 1px solid var(--tag-color, #212121);
        opacity: 0.25;
        margin: 0 0 2rem;
    }

    .blog-post .content .gatsby-resp-image-figcaption {
        margin-top: 0.4rem;
        text-align: center;
        font-weight: normal;
        font-size: smaller;
    }

    .blog-post ul {
        margin-left:0;
        margin-bottom: 1rem;
    }

    .blog-post ul li {
        margin-bottom: 0.5rem;
    }

    .blog-post p {
        margin-bottom: 1.2rem;
        line-height: 1.65;
    }

    .blog-post > p:first-of-type {
        font-size: 1.05em;
        line-height: 1.65;
    }

    .blog-post img {
        object-fit: contain;
        height: inherit;
        width: 100%;
        border: 1px solid lightgray;
        margin: 0 auto;
        display: block;
    }

    .content-ending-line {
        margin-top: 2rem;
        margin-bottom: 2rem;
    }

    .writing-ending {
        text-align: center;
        font-size: 1.5em;
        color: var(--tag-color, #000);
        margin: 1rem 0;
    }

    .dark .writing-ending {
        color: var(--tag-color, #F5F5F5);
    }

    .blog-post blockquote {
        margin: 2rem 0;
        padding: 0.75rem 1.5rem;
        border-left: 3px solid var(--tag-color, #212121);
        font-style: italic;
        font-size: 1.05em;
    }
    
    .blog-post blockquote p {
        margin: 0;
        margin-bottom: 0rem;
        padding: 0;
    }

    @media (max-width: 756px) {
        .blog-post h1:first-of-type {
            margin-top: 2rem;
            margin-bottom: 2rem;
        }

        @media (max-width: 620px) {
            .blog-post h1:first-of-type {
                font-size: 2rem;
                margin-top: 2rem;
                margin-bottom: 2rem;
            }

            h2 {
                font-size: 1.5rem;
            }

            h3 {
                font-size: 1.25rem;
            }

            h4 {
                font-size: 1rem;
            }
        }
    }
</style>