---
import BaseLayout from "./BaseLayout.astro"
import FormattedDate from "../components/FormattedDate.astro"
import Mastodon from "../components/Mastodon.astro"
import Comment from "../components/Comment.astro"
import BauhausBlock from "../components/BauhausBlock.astro"
import ReadingProgress from "../components/ReadingProgress.astro"
import { getCollection, render, type CollectionEntry } from "astro:content"
import { getTagColor, getCardColor } from "../config/colors"
import BauhausDivider from "../components/BauhausDivider.astro"
import TableOfContents from "../components/TableOfContents.astro"
type Props = CollectionEntry<"writings">;
const post = Astro.props

const tagColor = getCardColor(post.data.tags);

const comments = (await getCollection("comments", (comment) => {
  return comment.data.internalLink?.id === post.id
})).sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()).filter((comment) => comment.data.mastodon !== post.data.mastodon)

// Reading time estimate
const { remarkPluginFrontmatter, headings } = await render(post);
const body = post.body ?? '';
const wordCount = body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 220));
const relatedPosts = (await getCollection("writings", (entry) => {
    if (entry.id === post.id) {
        return false;
    }

    const entryTags = entry.data.tags ?? [];
    const postTags = post.data.tags ?? [];
    return entryTags.some((tag) => postTags.includes(tag));
}))
    .sort((left, right) => {
        const leftSharedTags = (left.data.tags ?? []).filter((tag) => (post.data.tags ?? []).includes(tag)).length;
        const rightSharedTags = (right.data.tags ?? []).filter((tag) => (post.data.tags ?? []).includes(tag)).length;

        if (leftSharedTags !== rightSharedTags) {
            return rightSharedTags - leftSharedTags;
        }

        return right.data.pubDate.valueOf() - left.data.pubDate.valueOf();
    })
    .slice(0, 3);
---
<BaseLayout title={post.data.title} description={post.data.summary} ogType="article" publishedDate={new Date(post.data.pubDate).toISOString()} tags={post.data.tags}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.summary,
    "datePublished": new Date(post.data.pubDate).toISOString(),
    "author": {
      "@type": "Person",
      "name": "Arttu Viljakainen",
      "url": "https://arttuv.com/author"
    },
    "publisher": {
      "@type": "Person",
      "name": "Arttu Viljakainen"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://arttuv.com/writings/${post.id}/`
    },
    "wordCount": wordCount,
    ...(post.data.tags ? { "keywords": post.data.tags.join(", ") } : {})
  })} />
  <ReadingProgress tagColor={tagColor} />
  <article class="blog-post" style={`--tag-color: ${tagColor}`}>
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="category">
        {post.data.tags.map((tag) => (
                                    <span><a href={`/tags/${tag}/`} class="card-tag" style={`color: ${getTagColor(tag)}; --tag-pill-color: ${getTagColor(tag)}`}>#{tag}</a></span>
        ))}
      </div>
    )}
    <BauhausBlock slug={post.id} tags={post.data.tags} direction="horizontal" />
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <FormattedDate date={new Date(post.data.pubDate)} />
      <span class="meta-separator">·</span>
      <span class="reading-time">{readingTime} min read</span>
    </div>
    {post.data.summary && (
      <div class="abstract">
        <span class="abstract-label">Abstract</span>
        <p>{post.data.summary}</p>
      </div>
    )}
    {post.data.updates && post.data.updates.length > 0 && (
      <div class="post-updates">
        <span class="post-updates-label">Updates</span>
        <ul>
          {post.data.updates.map((update) => (
            <li><strong>{update.date}</strong> {update.text}</li>
          ))}
        </ul>
      </div>
    )}
    <hr />
    {comments.length > 0 && (
      <div class="writing-notes">
        {comments.map((comment) => (
          <Comment {comment} />
        ))}
      </div>
    )}
    <div class="post-body">
      <TableOfContents headings={headings} slug={post.id} tags={post.data.tags} />
      <slot />
    </div>
    <BauhausDivider seed={post.id} height="80px" spacing="2.5rem" />
    <div class="writing-ending">•</div>
    {post.data.mastodon &&
      <Mastodon statusId={post.data.mastodon} />}
        {relatedPosts.length > 0 && (
            <aside class="related-posts" aria-labelledby="related-posts-heading">
                <h2 id="related-posts-heading">Read More</h2>
                <ul class="related-posts-list">
                    {relatedPosts.map((relatedPost) => (
                        <li>
                            <a href={`/${relatedPost.collection}/${relatedPost.id}/`}>{relatedPost.data.title}</a>
                            <FormattedDate date={new Date(relatedPost.data.pubDate)} />
                        </li>
                    ))}
                </ul>
            </aside>
        )}
  </article>
</BaseLayout>

<style is:global>
    .blog-post {
        max-width: 70ch;
        margin: 2rem auto;
    }

    .blog-post pre {
        overflow: scroll;
    }

    .blog-post .related-posts {
            margin-top: 2.5rem;
            padding-top: 1rem;
            border-top: 1px solid color-mix(in srgb, var(--tag-color, #212121) 22%, transparent);
            opacity: 0.88;
    }

    .blog-post .related-posts h2 {
        margin-top: 0;
            margin-bottom: 0.75rem;
            border-bottom: 0;
            padding-bottom: 0;
            font-size: 0.95rem;
            font-variant: normal;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-family: var(--font-condensed);
            color: var(--color-muted);
    }

        .blog-post .related-posts-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 0.5rem;
        }

        .blog-post .related-posts-list li {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem 0.75rem;
            align-items: baseline;
        }

        .blog-post .related-posts-list a {
            text-decoration: none;
        }

        .blog-post .related-posts-list a:hover {
            text-decoration: underline;
        }

        .blog-post .related-posts-list time {
            margin: 0;
            font-size: 0.72rem;
            color: var(--color-muted);
    }

    .writing-notes {
        margin: 1rem 2rem;
    }

    .blog-post h1, .blog-post h2, .blog-post h3, .blog-post h4, .blog-post h5 {
        padding-left:0;
        margin-left:0;
        padding-bottom:0;
        margin-top: 3rem;
        margin-bottom: 1rem;
        scroll-margin-top: 6rem;
    }

    .blog-post h2 {
        font-variant: small-caps;
        font-size: 1.5rem;
        letter-spacing: 0.02em;
        border-bottom: 1px solid var(--tag-color, #212121);
        padding-bottom: 0.35rem;
        opacity: 0.9;
    }

    .dark .blog-post h2 {
        border-bottom-color: var(--tag-color, #F5F5F5);
    }

    .blog-post h3 {
        font-style: italic;
        font-weight: 400;
    }

    .blog-post h1:first-of-type {
        font-size: 3rem;
        text-align: left;
        text-decoration: none;
        margin-left: 0px;
        padding-bottom:0;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        font-weight: 300;
    }

    .blog-post .category {
        margin-bottom: 0.5rem;
        padding-bottom:0;
        padding-top: 0px;
        padding-left:0;
        margin-top: 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }

    .blog-post .category span {
        display: inline-flex;
    }

    .blog-post .category .card-tag {
        font-size: 0.8rem;
        margin-right: 0;
    }

    /* Post meta: date + reading time */
    .blog-post .post-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .blog-post .post-meta time {
        margin-bottom: 0;
    }

    .blog-post .meta-separator {
        font-family: var(--font-condensed);
        font-size: 0.8rem;
        color: #999;
    }

    .blog-post .reading-time {
        font-family: var(--font-condensed);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #666;
    }

    .dark .blog-post .reading-time {
        color: #aaa;
    }

    .dark .blog-post .meta-separator {
        color: #666;
    }

    .blog-post time {
        display: block;
        font-family: var(--font-condensed);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #666;
        margin-top: 0;
        margin-bottom: 1.5rem;
    }

    .dark .blog-post time {
        color: #aaa;
    }

    /* Abstract / Summary */
    .blog-post .abstract {
        margin: 0 0 1.5rem;
        padding: 1.25rem 1.5rem;
        background: rgba(0, 0, 0, 0.025);
        border-left: 3px solid var(--tag-color, #212121);
        border-radius: 0 4px 4px 0;
    }

    .dark .blog-post .abstract {
        background: rgba(255, 255, 255, 0.04);
        border-left-color: var(--tag-color, #F5F5F5);
    }

    .blog-post .abstract-label {
        display: block;
        font-family: var(--font-condensed);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--tag-color, #212121);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .dark .blog-post .abstract-label {
        color: var(--tag-color, #F5F5F5);
    }

    .blog-post .abstract p {
        margin: 0;
        font-size: 0.95em;
        line-height: 1.55;
        color: #444;
        font-style: italic;
    }

    .dark .blog-post .abstract p {
        color: #bbb;
    }

    /* Post Updates */
    .blog-post .post-updates {
        margin: 0 0 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(0, 0, 0, 0.02);
        border-left: 3px solid #999;
        border-radius: 0 4px 4px 0;
        font-size: 0.85em;
    }

    .dark .blog-post .post-updates {
        background: rgba(255, 255, 255, 0.03);
        border-left-color: #666;
    }

    .blog-post .post-updates-label {
        display: block;
        font-family: var(--font-condensed);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #999;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .dark .blog-post .post-updates-label {
        color: #666;
    }

    .blog-post .post-updates ul {
        margin: 0;
        padding-left: 1.2rem;
        line-height: 1.55;
        color: #555;
    }

    .dark .blog-post .post-updates ul {
        color: #aaa;
    }

    .blog-post .post-updates li {
        margin-bottom: 0.4rem;
    }

    .blog-post .post-updates li:last-child {
        margin-bottom: 0;
    }

    .blog-post hr:not(.content-ending-line) {
        border: none;
        border-top: 1px solid var(--tag-color, #212121);
        opacity: 0.25;
        margin: 0 0 2rem;
    }

    .blog-post .content .gatsby-resp-image-figcaption {
        margin-top: 0.4rem;
        text-align: center;
        font-weight: normal;
        font-size: smaller;
    }

    .blog-post ul {
        margin-left:0;
        margin-bottom: 1rem;
    }

    .blog-post ul li {
        margin-bottom: 0.5rem;
    }

    .blog-post p {
        margin-bottom: 1.2rem;
        line-height: 1.7;
    }

    /* Prevent headings, blockquotes, and lists from sitting beside the floated TOC */
    .blog-post .post-body > h2,
    .blog-post .post-body > h3,
    .blog-post .post-body > h4,
    .blog-post .post-body > blockquote,
    .blog-post .post-body > ul,
    .blog-post .post-body > ol,
    .blog-post .post-body > pre,
    .blog-post .post-body > hr {
        clear: left;
    }

    /* Drop cap on first paragraph of the body */
    .blog-post .post-body > p:first-of-type::first-letter {
        float: left;
        font-family: var(--font-serif);
        font-size: 3.4em;
        line-height: 0.8;
        padding-right: 0.08em;
        padding-top: 0.07em;
        font-weight: 400;
        color: var(--tag-color, #212121);
    }

    .dark .blog-post .post-body > p:first-of-type::first-letter {
        color: var(--tag-color, #F5F5F5);
    }

    .blog-post .post-body > p:first-of-type {
        font-size: 1.05em;
        line-height: 1.65;
    }

    /* Image captions from markdown title attribute */
    .blog-post img {
        object-fit: contain;
        height: inherit;
        width: 100%;
        border: 1px solid lightgray;
        margin: 0 auto;
        display: block;
    }

    .blog-post img + em,
    .blog-post p:has(> img) + p > em:only-child {
        display: block;
        text-align: center;
        font-size: 0.85em;
        color: #666;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
        font-family: var(--font-condensed);
        font-style: normal;
    }

    .dark .blog-post img + em,
    .dark .blog-post p:has(> img) + p > em:only-child {
        color: #999;
    }

    .content-ending-line {
        margin-top: 3rem;
        margin-bottom: 2rem;
    }

    .writing-ending {
        text-align: center;
        font-size: 1.5em;
        color: var(--tag-color, #000);
        margin: 1rem 0;
    }

    .dark .writing-ending {
        color: var(--tag-color, #F5F5F5);
    }

    .blog-post blockquote {
        margin: 2rem 0;
        padding: 1rem 1.5rem;
        border-left: 3px solid var(--tag-color, #212121);
        font-style: italic;
        font-size: 1em;
        background: rgba(0, 0, 0, 0.015);
        border-radius: 0 4px 4px 0;
    }

    .dark .blog-post blockquote {
        background: rgba(255, 255, 255, 0.02);
        border-left-color: var(--tag-color, #F5F5F5);
    }

    .blog-post blockquote p {
        margin: 0;
        margin-bottom: 0rem;
        padding: 0;
        line-height: 1.6;
    }

    /* Section spacing */
    .blog-post .post-body > h2 {
        margin-top: 3.5rem;
    }

    .blog-post .post-body > h2:first-child {
        margin-top: 2rem;
    }

    @media (max-width: 756px) {
        .blog-post h1:first-of-type {
            margin-top: 2rem;
            margin-bottom: 2rem;
        }

        .blog-post .post-body > p:first-of-type::first-letter {
            font-size: 2.8em;
        }

        @media (max-width: 620px) {
            .blog-post h1:first-of-type {
                font-size: 2rem;
                margin-top: 2rem;
                margin-bottom: 2rem;
            }

            h2 {
                font-size: 1.5rem;
            }

            h3 {
                font-size: 1.25rem;
            }

            h4 {
                font-size: 1rem;
            }

            .blog-post .abstract {
                padding: 1rem 1.25rem;
            }

            .blog-post .post-body > p:first-of-type::first-letter {
                font-size: 2.5em;
            }
        }
    }
</style>