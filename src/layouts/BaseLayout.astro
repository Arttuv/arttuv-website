---
import { ClientRouter } from 'astro:transitions';
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import "../styles/global.css"
import "@fontsource-variable/roboto-serif"
import '@fontsource/newsreader';
import '@fontsource-variable/roboto-condensed';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  publishedDate?: string;
  tags?: string[];
  robots?: string;
}

const { title, description, ogType = "website", publishedDate, tags, robots } = Astro.props
const canonicalURL = Astro.url
const siteName = "Arttu Viljakainen"
const fullTitle = title === siteName ? title : `${title} | ${siteName}`
const ogImage = new URL("/images/og-default.png", Astro.site)
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  {robots && <meta name="robots" content={robots} />}
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:logo" content={new URL("/favicon.svg", Astro.site)} />
  {ogType === "article" && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}
  {ogType === "article" && tags && tags.map((tag) => (
    <meta property="article:tag" content={tag} />
  ))}

  <!-- Twitter / Mastodon card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{fullTitle}</title>
  <ClientRouter />
</head>
<body>
<Header />
<main>
  <slot />
</main>
<Footer />
<script is:inline>
  ;(function() {
    if (window.__themeControllerInitialized) {
      window.__syncThemeControls && window.__syncThemeControls()
      return
    }

    window.__themeControllerInitialized = true

    var themeKey = "theme"
    var mediaQuery = window.matchMedia("(prefers-color-scheme: dark)")
    var state = {
      confirming: false,
      pendingTheme: null,
    }

    function safeGetItem(key) {
      try {
        return typeof localStorage !== "undefined" ? localStorage.getItem(key) : null
      } catch {
        return null
      }
    }

    function safeSetItem(key, value) {
      try {
        if (typeof localStorage !== "undefined") {
          localStorage.setItem(key, value)
        }
      } catch {
      }
    }

    function getStoredTheme() {
      var theme = safeGetItem(themeKey)
      return theme === "light" || theme === "dark" ? theme : null
    }

    function getSystemTheme() {
      return mediaQuery.matches ? "dark" : "light"
    }

    function getCurrentTheme() {
      if (state.confirming && state.pendingTheme) {
        return state.pendingTheme
      }

      return getStoredTheme() || getSystemTheme()
    }

    function applyTheme(theme) {
      if (theme === "light") {
        document.documentElement.classList.remove("dark")
      } else {
        document.documentElement.classList.add("dark")
      }
    }

    function syncThemeControls() {
      var isDark = document.documentElement.classList.contains("dark")
      var confirming = state.confirming

      document.querySelectorAll("[data-theme-control]").forEach(function(control) {
        control.setAttribute("data-confirming", confirming ? "true" : "false")

        var toggle = control.querySelector(".theme-toggle")
        var confirmInline = control.querySelector(".theme-confirm-inline")

        if (toggle) {
          toggle.setAttribute("aria-pressed", String(isDark))
          toggle.setAttribute("aria-expanded", String(confirming))
        }

        if (confirmInline) {
          confirmInline.setAttribute("aria-hidden", String(!confirming))
        }
      })
    }

    function syncTheme() {
      applyTheme(getCurrentTheme())
      syncThemeControls()
    }

    window.__syncThemeControls = syncTheme

    syncTheme()
    document.addEventListener("astro:after-swap", syncTheme)

    function handleSystemThemeChange() {
      if (!getStoredTheme() && !state.confirming) {
        syncTheme()
      }
    }

    if (typeof mediaQuery.addEventListener === "function") {
      mediaQuery.addEventListener("change", handleSystemThemeChange)
    } else if (typeof mediaQuery.addListener === "function") {
      mediaQuery.addListener(handleSystemThemeChange)
    }

    document.addEventListener("click", function(e) {
      var target = e.target
      if (!target || !target.closest) return

      if (target.closest(".theme-consent-confirm")) {
        var confirmedTheme = state.pendingTheme || getCurrentTheme()
        state.confirming = false
        state.pendingTheme = null
        safeSetItem(themeKey, confirmedTheme)
        applyTheme(confirmedTheme)
        syncThemeControls()
        return
      }

      if (target.closest(".theme-consent-cancel")) {
        state.confirming = false
        state.pendingTheme = null
        syncTheme()
        return
      }

      if (!target.closest(".theme-toggle")) return

      var currentTheme = document.documentElement.classList.contains("dark") ? "dark" : "light"
      var nextTheme = currentTheme === "dark" ? "light" : "dark"

      if (getStoredTheme()) {
        applyTheme(nextTheme)
        safeSetItem(themeKey, nextTheme)
        syncThemeControls()
        return
      }

      state.confirming = true
      state.pendingTheme = nextTheme
      applyTheme(nextTheme)
      syncThemeControls()
    })
  })()
</script>
</body>
</html>